<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VOID REALM</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@700;900&family=Rajdhani:wght@400;500;600;700&display=swap');
:root{--fire:#ff6a00;--void:#06000f;--cyber:#00ffe7;--gold:#ffd700;--purple:#7722ff;}
*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--void);font-family:'Rajdhani',sans-serif;color:#fff;overflow:hidden;user-select:none;}

/* ── TITLE ── */
#title-screen{position:fixed;inset:0;background:radial-gradient(ellipse at 50% 40%,#1a0035,#06000f 70%);display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:300;transition:opacity .8s;}
#title-screen h1{font-family:'Cinzel Decorative',cursive;font-size:clamp(2rem,7vw,5rem);background:linear-gradient(135deg,#ff6a00,#ffd700,#00ffe7,#ff00cc);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;letter-spacing:5px;animation:glow 2s ease-in-out infinite;}
@keyframes glow{0%,100%{filter:brightness(1)}50%{filter:brightness(1.5)}}
.title-sub{font-size:.85rem;color:#555;letter-spacing:4px;text-transform:uppercase;margin:10px 0 10px;}
.title-icons-row{display:flex;gap:22px;margin:18px 0 28px;animation:floatY 3s ease-in-out infinite;}
@keyframes floatY{0%,100%{transform:translateY(0)}50%{transform:translateY(-9px)}}
.start-btn{padding:15px 52px;font-family:'Cinzel Decorative',cursive;font-size:1rem;background:linear-gradient(135deg,#ff6a00,#cc0044);border:2px solid #ff6a00;color:#fff;cursor:pointer;clip-path:polygon(10px 0%,100% 0%,calc(100% - 10px) 100%,0% 100%);letter-spacing:2px;transition:all .2s;box-shadow:0 0 28px #ff6a0055;}
.start-btn:hover{transform:scale(1.07);box-shadow:0 0 55px #ff6a00aa;}
.title-controls{margin-top:24px;font-size:.68rem;color:#3a3a3a;letter-spacing:2px;text-align:center;line-height:2.1;}

/* ── LAYOUT ── */
#game-layout{display:none;width:100vw;height:100vh;flex-direction:column;align-items:center;}

/* ── HUD ── */
#hud{width:100%;max-width:980px;padding:5px 14px;background:linear-gradient(90deg,#110022dd,#06000faa);border-bottom:1px solid #ffffff0c;display:flex;align-items:center;gap:10px;flex-wrap:wrap;flex-shrink:0;}
.hud-title{font-family:'Cinzel Decorative',cursive;font-size:.68rem;color:var(--gold);white-space:nowrap;letter-spacing:2px;}
.stat-grp{display:flex;flex-direction:column;gap:2px;min-width:108px;}
.bar-lbl{font-size:.58rem;color:#777;display:flex;justify-content:space-between;letter-spacing:1px;}
.bar-track{height:6px;background:#ffffff10;border-radius:3px;overflow:hidden;}
.bar-fill{height:100%;border-radius:3px;transition:width .12s;}
.b-hp{background:linear-gradient(90deg,#22ff88,#00cc55);box-shadow:0 0 4px #22ff8866;}
.b-mp{background:linear-gradient(90deg,#4488ff,#0044ff);box-shadow:0 0 4px #4488ff66;}
.b-xp{background:linear-gradient(90deg,#ffd700,#ff8800);box-shadow:0 0 4px #ffd70066;}
.hud-nums{display:flex;gap:12px;font-size:.76rem;color:#aaa;white-space:nowrap;}
.hud-nums b{color:var(--gold);}
.hud-combo{font-family:'Cinzel Decorative',cursive;font-size:.72rem;color:#ff6a00;min-width:84px;text-align:right;}

/* ── CANVAS ── */
#gameCanvas{display:block;cursor:crosshair;box-shadow:0 0 36px #00ffe722,0 0 70px #ff6a0018;flex:1;max-width:980px;width:100%;}

/* ── ACTION BAR ── */
#action-bar{width:100%;max-width:980px;padding:6px 14px;background:linear-gradient(90deg,#06000faa,#110022dd);border-top:1px solid #ffffff0c;display:flex;align-items:center;justify-content:center;gap:8px;flex-shrink:0;}
.ab-wrap{display:flex;flex-direction:column;align-items:center;gap:3px;}
.ab-btn{width:58px;height:58px;border-radius:10px;border:2px solid #ffffff1a;background:#ffffff06;display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;position:relative;transition:all .13s;overflow:hidden;flex-shrink:0;}
.ab-btn:hover{transform:translateY(-2px);border-color:#ffffff44;}
.ab-btn.ready{border-color:var(--cyber);box-shadow:0 0 10px #00ffe733;}
.ab-btn.cooling{opacity:.65;border-color:#ffffff18;}
.ab-btn.pressed{transform:scale(.92);border-color:#ffdd00 !important;box-shadow:0 0 18px #ffdd0066 !important;}
.ab-icon-wrap{width:32px;height:32px;display:flex;align-items:center;justify-content:center;}
.ab-label{font-size:.47rem;color:#666;letter-spacing:.5px;text-align:center;line-height:1.2;}
.ab-key{font-size:.55rem;color:#444;letter-spacing:1px;font-weight:700;}
.ab-cd-overlay{position:absolute;inset:0;background:#000000bb;display:flex;align-items:center;justify-content:center;font-family:'Cinzel Decorative',cursive;font-size:.82rem;color:#fff;border-radius:8px;pointer-events:none;}
.ab-btn.ready .ab-cd-overlay{display:none;}
.ab-divider{width:1px;height:46px;background:#ffffff0e;flex-shrink:0;margin:0 2px;}
.atk-hint{font-size:.6rem;color:#333;letter-spacing:.8px;text-align:center;line-height:1.8;padding:0 4px;}

/* ── WAVE UNLOCK TOAST ── */
#unlock-toast{position:fixed;top:80px;right:18px;background:linear-gradient(135deg,#110022,#1a003a);border:1px solid var(--gold);border-radius:12px;padding:12px 18px;max-width:220px;z-index:250;display:none;animation:slideIn .4s ease;}
@keyframes slideIn{from{opacity:0;transform:translateX(30px)}to{opacity:1;transform:translateX(0)}}
#unlock-toast h4{font-family:'Cinzel Decorative',cursive;font-size:.72rem;color:var(--gold);margin-bottom:4px;}
#unlock-toast p{font-size:.68rem;color:#aaa;line-height:1.4;}

/* ── PROGRESS PANEL ── */
#progress-btn{position:fixed;top:58px;right:14px;background:#110022cc;border:1px solid var(--purple);border-radius:8px;padding:6px 12px;cursor:pointer;font-size:.65rem;color:var(--gold);letter-spacing:1px;z-index:200;transition:all .2s;font-family:'Rajdhani',sans-serif;}
#progress-btn:hover{background:#220044cc;box-shadow:0 0 12px var(--purple)44;}
#progress-panel{display:none;position:fixed;top:56px;right:14px;width:270px;background:linear-gradient(160deg,#110022,#06000f);border:1px solid var(--purple)44;border-radius:14px;padding:18px;z-index:210;box-shadow:0 0 40px var(--purple)33;}
#progress-panel h3{font-family:'Cinzel Decorative',cursive;font-size:.85rem;color:var(--gold);margin-bottom:12px;text-align:center;}
.unlock-row{display:flex;align-items:center;gap:10px;padding:7px 0;border-bottom:1px solid #ffffff08;}
.unlock-row:last-child{border-bottom:none;}
.unlock-icon{width:32px;height:32px;flex-shrink:0;display:flex;align-items:center;justify-content:center;}
.unlock-info{flex:1;}
.unlock-name{font-size:.75rem;color:#ccc;font-weight:600;}
.unlock-desc{font-size:.6rem;color:#555;margin-top:1px;}
.unlock-wave{font-size:.6rem;font-family:'Cinzel Decorative',cursive;padding:2px 7px;border-radius:4px;background:#ffffff0a;border:1px solid #ffffff11;color:#777;white-space:nowrap;}
.unlock-wave.done{color:var(--gold);border-color:var(--gold)44;background:#ffd70011;}
.close-btn{position:absolute;top:10px;right:12px;background:none;border:none;color:#555;cursor:pointer;font-size:1rem;}

/* ── SKILL TREE ── */
#skill-overlay{display:none;position:fixed;inset:0;background:#000000bb;align-items:center;justify-content:center;z-index:180;}
.skill-panel{background:linear-gradient(160deg,#110022,#06000f);border:1px solid var(--purple)44;border-radius:16px;padding:26px 28px;max-width:520px;width:92%;box-shadow:0 0 50px var(--purple)33;}
.skill-panel h2{font-family:'Cinzel Decorative',cursive;font-size:1.4rem;color:var(--gold);text-align:center;margin-bottom:5px;text-shadow:0 0 18px var(--gold);}
.skill-lvl{text-align:center;font-size:.75rem;color:#666;letter-spacing:2px;margin-bottom:18px;}
.skill-grid{display:grid;grid-template-columns:1fr 1fr;gap:9px;}
.skill-card{background:#ffffff05;border:1.5px solid var(--purple)22;border-radius:10px;padding:13px 14px;cursor:pointer;transition:all .18s;}
.skill-card:hover{background:var(--purple)18;border-color:var(--purple)aa;transform:translateY(-2px);}
.skill-card h3{font-size:.88rem;color:var(--cyber);margin-bottom:3px;}
.skill-card p{font-size:.68rem;color:#777;line-height:1.4;}
.sk-icon-wrap{width:28px;height:28px;margin-bottom:5px;}

/* ── END ── */
#end-overlay{display:none;position:fixed;inset:0;background:#000000cc;align-items:center;justify-content:center;z-index:280;flex-direction:column;gap:12px;}
#end-overlay h2{font-family:'Cinzel Decorative',cursive;font-size:clamp(2rem,5vw,4rem);color:var(--gold);text-shadow:0 0 40px var(--gold);animation:glow 1.2s infinite;}
#end-overlay p{font-size:.95rem;color:#999;letter-spacing:2px;}
.stat-row{display:flex;gap:16px;flex-wrap:wrap;justify-content:center;margin:4px 0;}
.stat-pill{background:#ffffff08;border:1px solid #ffffff0f;border-radius:8px;padding:7px 16px;text-align:center;}
.stat-pill b{display:block;font-size:1.15rem;color:var(--gold);}
.stat-pill span{font-size:.6rem;color:#555;letter-spacing:1px;text-transform:uppercase;}

/* ── FLOATERS ── */
.dmg-float{position:fixed;font-family:'Cinzel Decorative',cursive;font-weight:900;pointer-events:none;animation:floatUp .85s forwards;z-index:260;}
@keyframes floatUp{0%{opacity:1;transform:translateY(0) scale(1)}100%{opacity:0;transform:translateY(-52px) scale(1.25)}}
#wave-announce{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);font-family:'Cinzel Decorative',cursive;font-size:clamp(1.5rem,4vw,3rem);color:var(--gold);text-shadow:0 0 40px var(--gold),0 0 80px #ff6a00;pointer-events:none;z-index:290;display:none;animation:waveAnn 2s forwards;}
@keyframes waveAnn{0%{opacity:0;transform:translate(-50%,-50%) scale(.5)}20%{opacity:1;transform:translate(-50%,-50%) scale(1.08)}70%{opacity:1;transform:translate(-50%,-50%) scale(1)}100%{opacity:0;transform:translate(-50%,-50%) scale(.92)}}
</style>
</head>
<body>

<!-- TITLE -->
<div id="title-screen">
  <div class="title-icons-row" id="title-icon-row"></div>
  <h1>VOID REALM</h1>
  <p class="title-sub">Shadow · Ember · Rogue · Striker</p>
  <button class="start-btn" onclick="startGame()">⚔ ENTER THE REALM ⚔</button>
  <div class="title-controls">
    WASD — MOVE &nbsp;|&nbsp; LEFT CLICK — ATTACK &nbsp;|&nbsp; RIGHT CLICK — SPECIAL<br>
    CLICK BUTTONS OR PRESS 1–4 — ABILITIES &nbsp;|&nbsp; SPACE — DASH
  </div>
</div>

<!-- GAME LAYOUT -->
<div id="game-layout">
  <div id="hud">
    <div class="hud-title">⚔ VOID KNIGHT</div>
    <div class="stat-grp">
      <div class="bar-lbl"><span>HP</span><span id="hp-val">100</span></div>
      <div class="bar-track"><div class="bar-fill b-hp" id="hp-bar" style="width:100%"></div></div>
    </div>
    <div class="stat-grp">
      <div class="bar-lbl"><span>MP</span><span id="mp-val">60</span></div>
      <div class="bar-track"><div class="bar-fill b-mp" id="mp-bar" style="width:100%"></div></div>
    </div>
    <div class="stat-grp">
      <div class="bar-lbl"><span>XP</span><span id="xp-val">0/100</span></div>
      <div class="bar-track"><div class="bar-fill b-xp" id="xp-bar" style="width:0%"></div></div>
    </div>
    <div class="hud-nums">LVL <b id="lv-val">1</b> &nbsp; WAVE <b id="wave-val">1</b> &nbsp; KILLS <b id="kills-val">0</b></div>
    <div class="hud-combo" id="combo-disp"></div>
  </div>

  <canvas id="gameCanvas"></canvas>

  <div id="action-bar">
    <div class="atk-hint">LEFT CLICK<br>ATTACK</div>
    <div class="atk-hint">RIGHT CLICK<br>SPECIAL</div>
    <div class="ab-divider"></div>
    <div class="ab-wrap">
      <div class="ab-btn ready" id="ab0" onclick="triggerAbility(0)">
        <div class="ab-icon-wrap" id="ab0-icon"></div>
        <div class="ab-label">FIRESTORM</div>
        <div class="ab-cd-overlay" id="ab0-cd"></div>
      </div>
      <div class="ab-key">[1]</div>
    </div>
    <div class="ab-wrap">
      <div class="ab-btn ready" id="ab1" onclick="triggerAbility(1)">
        <div class="ab-icon-wrap" id="ab1-icon"></div>
        <div class="ab-label">THUNDER</div>
        <div class="ab-cd-overlay" id="ab1-cd"></div>
      </div>
      <div class="ab-key">[2]</div>
    </div>
    <div class="ab-wrap">
      <div class="ab-btn ready" id="ab2" onclick="triggerAbility(2)">
        <div class="ab-icon-wrap" id="ab2-icon"></div>
        <div class="ab-label">VOID SPIN</div>
        <div class="ab-cd-overlay" id="ab2-cd"></div>
      </div>
      <div class="ab-key">[3]</div>
    </div>
    <div class="ab-wrap">
      <div class="ab-btn ready" id="ab3" onclick="triggerAbility(3)">
        <div class="ab-icon-wrap" id="ab3-icon"></div>
        <div class="ab-label">DEATH NOVA</div>
        <div class="ab-cd-overlay" id="ab3-cd"></div>
      </div>
      <div class="ab-key">[4]</div>
    </div>
    <div class="ab-divider"></div>
    <div class="atk-hint">SPACE<br>DASH</div>
    <div style="margin-left:auto;">
      <button id="progress-btn" onclick="toggleProgress()">📜 PROGRESS</button>
    </div>
  </div>
</div>

<!-- PROGRESS PANEL -->
<div id="progress-panel" style="position:fixed;display:none;">
  <button class="close-btn" onclick="toggleProgress()">✕</button>
  <h3>⚔ WAVE UNLOCKS</h3>
  <div id="unlock-list"></div>
</div>

<!-- UNLOCK TOAST -->
<div id="unlock-toast"><h4 id="unlock-toast-title">UNLOCKED!</h4><p id="unlock-toast-desc"></p></div>

<!-- SKILL OVERLAY -->
<div id="skill-overlay">
  <div class="skill-panel">
    <h2>✦ LEVEL UP!</h2>
    <div class="skill-lvl" id="skill-lvl-txt">CHOOSE AN UPGRADE</div>
    <div class="skill-grid" id="skill-grid"></div>
  </div>
</div>

<!-- END SCREEN -->
<div id="end-overlay">
  <h2>GAME OVER</h2>
  <p id="end-sub">YOU HAVE FALLEN</p>
  <div class="stat-row" id="end-stats"></div>
  <button class="start-btn" onclick="restartGame()">RISE AGAIN</button>
</div>

<div id="wave-announce"></div>

<script>
// ═══════════════════════════════════════════
//   VOID REALM  ·  Full Engine v3
// ═══════════════════════════════════════════

const canvas = document.getElementById('gameCanvas');
const ctx    = canvas.getContext('2d');
let W, H;

function resize() {
  const hudH = document.getElementById('hud').offsetHeight || 42;
  const barH = document.getElementById('action-bar').offsetHeight || 76;
  W = canvas.width  = Math.min(window.innerWidth, 980);
  H = canvas.height = Math.max(180, window.innerHeight - hudH - barH);
}

// ── SVG ICON HELPERS ──────────────────────────────────────
function svgIcon(paths, vb='0 0 32 32') {
  return `<svg viewBox="${vb}" width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">${paths}</svg>`;
}

// Ability icons (SVG strings)
const ABILITY_SVG = [
  // 0 Firestorm — flame burst
  svgIcon(`<path d="M16 28 C10 24 6 18 9 12 C10 16 13 14 12 10 C15 13 14 8 16 4 C18 8 17 13 20 10 C19 14 22 16 23 12 C26 18 22 24 16 28Z" fill="#ff6a00"/><circle cx="16" cy="20" r="4" fill="#ffdd00" opacity=".8"/>`),
  // 1 Thunder — lightning bolt
  svgIcon(`<polygon points="20,4 10,17 15,17 12,28 22,15 17,15" fill="#ffe044"/><polygon points="20,4 10,17 15,17 12,28 22,15 17,15" fill="none" stroke="#ffffff44" stroke-width="1"/>`),
  // 2 Void Spin — swirl
  svgIcon(`<path d="M16 4 A12 12 0 1 1 4 16" fill="none" stroke="#aa44ff" stroke-width="3" stroke-linecap="round"/><path d="M16 8 A8 8 0 1 0 8 16" fill="none" stroke="#cc88ff" stroke-width="2.5" stroke-linecap="round"/><circle cx="16" cy="16" r="3" fill="#aa44ff"/>`),
  // 3 Death Nova — skull-like burst
  svgIcon(`<circle cx="16" cy="16" r="11" fill="none" stroke="#cc0033" stroke-width="2"/><circle cx="16" cy="15" r="5" fill="#cc0033"/><circle cx="13" cy="14" r="1.5" fill="#ff8888"/><circle cx="19" cy="14" r="1.5" fill="#ff8888"/><path d="M13 19 Q16 21 19 19" fill="none" stroke="#ff8888" stroke-width="1.5"/><line x1="16" y1="2" x2="16" y2="6" stroke="#cc003388" stroke-width="2"/><line x1="26" y1="6" x2="23" y2="9" stroke="#cc003388" stroke-width="2"/><line x1="30" y1="16" x2="26" y2="16" stroke="#cc003388" stroke-width="2"/><line x1="26" y1="26" x2="23" y2="23" stroke="#cc003388" stroke-width="2"/><line x1="16" y1="30" x2="16" y2="26" stroke="#cc003388" stroke-width="2"/><line x1="6" y1="26" x2="9" y2="23" stroke="#cc003388" stroke-width="2"/><line x1="2" y1="16" x2="6" y2="16" stroke="#cc003388" stroke-width="2"/><line x1="6" y1="6" x2="9" y2="9" stroke="#cc003388" stroke-width="2"/>`)
];

// Title decoration SVGs
const TITLE_SVG = [
  svgIcon(`<path d="M16 4 L18 13 L28 13 L20 19 L23 28 L16 22 L9 28 L12 19 L4 13 L14 13Z" fill="#ffd700"/>`,'0 0 32 32'),
  svgIcon(`<rect x="14" y="3" width="4" height="22" rx="2" fill="#cc8844"/><path d="M10 3 L22 3 L20 8 L12 8Z" fill="#ffaa44"/><path d="M13 9 Q16 7 19 9 L22 25 L16 28 L10 25Z" fill="#ff6a00" opacity=".9"/><ellipse cx="16" cy="26" rx="4" ry="2" fill="#cc3300"/>`,'0 0 32 32'),
  svgIcon(`<path d="M16 2 L20 12 L30 12 L22 18 L25 28 L16 22 L7 28 L10 18 L2 12 L12 12Z" fill="none" stroke="#00ffe7" stroke-width="2"/><circle cx="16" cy="15" r="4" fill="#00ffe744"/>`,'0 0 32 32'),
  svgIcon(`<circle cx="16" cy="16" r="12" fill="none" stroke="#7722ff" stroke-width="2.5"/><path d="M16 4 L16 28 M4 16 L28 16 M7 7 L25 25 M25 7 L7 25" stroke="#7722ff44" stroke-width="1"/><circle cx="16" cy="16" r="4" fill="#7722ff"/>`,'0 0 32 32'),
];

function renderSvgButtons() {
  ABILITY_SVG.forEach((svg,i)=>{
    document.getElementById('ab'+i+'-icon').innerHTML = svg;
  });
  const row = document.getElementById('title-icon-row');
  TITLE_SVG.forEach(svg=>{
    const d=document.createElement('div');d.style.cssText='width:48px;height:48px;';d.innerHTML=svg;row.appendChild(d);
  });
}

// ── WAVE UNLOCK SYSTEM ────────────────────────────────────
const WAVE_UNLOCKS = [
  { wave:3,  id:'dash_upgrade',  name:'Enhanced Dash',     desc:'Dash deals damage on exit',    icon:svgIcon(`<path d="M4 16 L28 16 M20 8 L28 16 L20 24" fill="none" stroke="#00ffe7" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>`), apply:p=>{p.perks.push('dashatk');} },
  { wave:5,  id:'triple_shot',   name:'Tri-Shot',           desc:'Special fires 5 projectiles',  icon:svgIcon(`<line x1="16" y1="28" x2="16" y2="4" stroke="#ff6a00" stroke-width="3"/><line x1="16" y1="28" x2="4" y2="8" stroke="#ff6a00" stroke-width="2"/><line x1="16" y1="28" x2="28" y2="8" stroke="#ff6a00" stroke-width="2"/>`), apply:p=>{p.perks.push('trishot');} },
  { wave:7,  id:'lifesteal',     name:'Lifesteal',          desc:'Steal 15% HP on every hit',    icon:svgIcon(`<path d="M16 26 C8 20 4 14 8 10 C10 8 14 8 16 12 C18 8 22 8 24 10 C28 14 24 20 16 26Z" fill="#ff4466"/>`), apply:p=>{p.perks.push('vamp');} },
  { wave:10, id:'combo2x',       name:'Combo Inferno',      desc:'Combo damage bonus ×2',        icon:svgIcon(`<text x="4" y="22" font-size="14" fill="#ff6a00" font-weight="bold">×2</text><path d="M4 4 L12 28 M12 4 L20 28" fill="none" stroke="#ff6a0066" stroke-width="2"/>`), apply:p=>{p.perks.push('combo2x');} },
  { wave:12, id:'cleave',        name:'Blade Cleave',       desc:'Attacks hit in full arc',       icon:svgIcon(`<path d="M16 26 L4 8 Q16 4 28 8Z" fill="#ccaa44" opacity=".7"/><rect x="14" y="14" width="4" height="16" rx="2" fill="#887744"/>`), apply:p=>{p.perks.push('cleave');} },
  { wave:15, id:'nova2',         name:'Death Spiral',       desc:'Death Nova fires 8 bolts',     icon:svgIcon(`<circle cx="16" cy="16" r="6" fill="#cc003366"/><circle cx="16" cy="16" r="3" fill="#cc0033"/>${[...Array(8)].map((_,k)=>{const a=k*Math.PI*2/8;return `<line x1="${16+Math.cos(a)*6}" y1="${16+Math.sin(a)*6}" x2="${16+Math.cos(a)*14}" y2="${16+Math.sin(a)*14}" stroke="#cc003388" stroke-width="2"/>`}).join('')}`), apply:p=>{p.perks.push('nova2');} },
  { wave:18, id:'chain2',        name:'Chain Storm',        desc:'Thunder hits 3 extra enemies', icon:svgIcon(`<polygon points="20,4 10,16 16,16 13,28 23,14 17,14" fill="#ffe044"/><path d="M24 8 L28 4 M28 16 L32 16 M24 24 L28 28" stroke="#ffe04488" stroke-width="2"/>`), apply:p=>{p.perks.push('chain2');} },
  { wave:20, id:'berserk',       name:'Berserker',          desc:'+40% ATK, −20% defense',       icon:svgIcon(`<path d="M8 4 L24 4 L28 16 L16 28 L4 16Z" fill="#ff220044" stroke="#ff2200" stroke-width="2"/><text x="11" y="21" font-size="13" fill="#ff4400" font-weight="bold">!</text>`), apply:p=>{p.atk=Math.floor(p.atk*1.4);p.perks.push('berserk');} },
];

let waveUnlocksDone = new Set();

function checkWaveUnlocks(wave, player) {
  WAVE_UNLOCKS.forEach(u=>{
    if(u.wave===wave && !waveUnlocksDone.has(u.id)){
      waveUnlocksDone.add(u.id);
      u.apply(player);
      showUnlockToast(u.name, u.desc);
    }
  });
  renderUnlockList(wave);
}

function showUnlockToast(name, desc) {
  const t=document.getElementById('unlock-toast');
  document.getElementById('unlock-toast-title').textContent='🔓 UNLOCKED: '+name;
  document.getElementById('unlock-toast-desc').textContent=desc;
  t.style.display='block';
  clearTimeout(t._timer);
  t._timer=setTimeout(()=>{t.style.display='none';},3200);
}

function renderUnlockList(currentWave) {
  const list=document.getElementById('unlock-list');
  list.innerHTML='';
  WAVE_UNLOCKS.forEach(u=>{
    const done=waveUnlocksDone.has(u.id);
    const row=document.createElement('div');row.className='unlock-row';
    row.innerHTML=`
      <div class="unlock-icon" style="opacity:${done?1:.3}">${u.icon}</div>
      <div class="unlock-info">
        <div class="unlock-name" style="color:${done?'#fff':'#555'}">${u.name}</div>
        <div class="unlock-desc">${u.desc}</div>
      </div>
      <div class="unlock-wave ${done?'done':''}">W${u.wave}</div>`;
    list.appendChild(row);
  });
}

function toggleProgress() {
  const p=document.getElementById('progress-panel');
  const btn=document.getElementById('progress-btn');
  if(p.style.display==='none'||p.style.display===''){
    p.style.display='block';btn.style.opacity='0';
    if(game)renderUnlockList(game.wave);
  } else {
    p.style.display='none';btn.style.opacity='1';
  }
}

