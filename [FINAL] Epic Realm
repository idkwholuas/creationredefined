  let ex,ey;
  if(side===0){ex=Math.random()*W;ey=-60;}
  else if(side===1){ex=W+60;ey=Math.random()*H;}
  else if(side===2){ex=Math.random()*W;ey=H+60;}
  else{ex=-60;ey=Math.random()*H;}
  const ti=Math.min(Math.floor(Math.random()*(1+wave*0.6)),ETYPES.length-1);
  const t=ETYPES[ti],sc=1+(wave-1)*0.1;
  return{x:ex,y:ey,vx:0,vy:0,typeIdx:ti,color:t.color,size:t.size,
    hp:Math.floor(t.hp*sc),maxHp:Math.floor(t.hp*sc),
    spd:t.spd+(wave-1)*0.04,atk:Math.floor(t.atk*sc),xp:t.xp,range:t.range,
    atkTimer:0,atkCooldown:75,hurtFlash:0,alive:true,wobble:Math.random()*Math.PI*2};
}

