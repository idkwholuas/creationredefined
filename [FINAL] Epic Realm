  el.textContent=dmg;document.body.appendChild(el);setTimeout(()=>el.remove(),880);
}

// ── COMBAT ─────────────────────────────────────────────────
function aimDir(p){const dx=mouseX-p.x,dy=mouseY-p.y,l=Math.hypot(dx,dy)||1;return{nx:dx/l,ny:dy/l,dx,dy};}

function tryAttack(p){
  if(!p.atkReady||pendingLevelUp)return;
  p.attacking=true;p.atkTimer=12;p.atkReady=false;
  p.combo=Math.min(p.combo+1,8);p.comboTimer=72;
  const{nx,ny,dx}=aimDir(p);
  if(Math.abs(dx)>4)p.facing=dx>0?1:-1;
  const cBonus=p.perks.includes('combo2x')?p.combo*.2:p.combo*.1;
  const dmg=Math.floor(p.atk*(1+cBonus));
  const range=p.perks.includes('cleave')?72:56;
  game.enemies.forEach(e=>{
    if(!e.alive)return;
    const ex=e.x-p.x,ey=e.y-p.y,d=Math.hypot(ex,ey);
    if(d>range+e.size/2)return;
    if(p.perks.includes('cleave')||(ex*nx+ey*ny)/d>0.3)doHit(e,dmg,p);
  });
  burst(p.x+nx*38,p.y+ny*38,'#ffdd00',6,3,4);
  setTimeout(()=>p.atkReady=true,(18/p.atkSpd)*16.67);
}

function trySpecial(p){
  if(!p.specialReady||p.mp<10||pendingLevelUp)return;
  p.mp=Math.max(0,p.mp-10);p.specialReady=false;
  const{nx,ny}=aimDir(p);
  const shots=p.perks.includes('trishot')?5:3;
  for(let i=0;i<shots;i++){
    const off=(i-(shots-1)/2)*.18,a=Math.atan2(ny,nx)+off;
    game.projectiles.push({x:p.x,y:p.y,vx:Math.cos(a)*7,vy:Math.sin(a)*7,r:8,color:'#ff6a00',dmg:Math.floor(p.atk*1.6),owner:'player',life:56});
  }
  burst(p.x,p.y,'#ff6a00',10,4,5);
  setTimeout(()=>p.specialReady=true,p.specialCooldown*16.67);
}

function tryDash(p){
  if(!p.dashReady||pendingLevelUp)return;
  if(p.perks.includes('dashatk'))p._dashAtk=true;
  p.dashDur=14;p.invincible=22;p.dashReady=false;
  let dvx=(keys['ArrowRight']||keys['KeyD']?1:keys['ArrowLeft']||keys['KeyA']?-1:p.facing)*7.5;
  let dvy=(keys['ArrowDown']||keys['KeyS']?1:keys['ArrowUp']||keys['KeyW']?-1:0)*7.5;
  if(dvx===0&&dvy===0)dvx=p.facing*7.5;
  p.dashVx=dvx;p.dashVy=dvy;
  burst(p.x,p.y,'#00ffe7',12,4,4);
  setTimeout(()=>p.dashReady=true,p.dashCooldown*16.67);
}

function tryAbility(p,idx){
  const ab=p.abilities[idx];
  if(!ab||!ab.ready||p.mp<ab.cost||pendingLevelUp)return;
  p.mp=Math.max(0,p.mp-ab.cost);ab.ready=false;ab.timer=ab.cd;
  if(idx===0){
    for(let k=0;k<8;k++){const a=k*Math.PI*2/8;game.projectiles.push({x:p.x,y:p.y,vx:Math.cos(a)*5.5,vy:Math.sin(a)*5.5,r:9,color:'#ff3300',dmg:Math.floor(p.atk*2.2),owner:'player',life:65});}
    burst(p.x,p.y,'#ff6600',22,5,6);
  }else if(idx===1){
    const cnt=p.perks.includes('chain2')?7:4;
    [...game.enemies].filter(e=>e.alive).sort((a,b)=>Math.hypot(a.x-p.x,a.y-p.y)-Math.hypot(b.x-p.x,b.y-p.y)).slice(0,cnt).forEach(e=>{doHit(e,Math.floor(p.atk*2.8),p);burst(e.x,e.y,'#44aaff',7,3,4);});
    burst(p.x,p.y,'#44aaff',12,5,4);
  }else if(idx===2){
    game.enemies.forEach(e=>{if(e.alive&&Math.hypot(e.x-p.x,e.y-p.y)<102)doHit(e,Math.floor(p.atk*2),p);});
    burst(p.x,p.y,'#aa00ff',22,5,5);
  }else if(idx===3){
    const resist=p.perks.includes('berserk')?1.3:1;
    game.enemies.forEach(e=>{if(e.alive&&Math.hypot(e.x-p.x,e.y-p.y)<152)doHit(e,Math.floor(p.atk*4.5*resist),p);});
    burst(p.x,p.y,'#ffffff',32,7,8);burst(p.x,p.y,'#cc0022',20,5,5);
    if(p.perks.includes('nova2')){for(let k=0;k<8;k++){const a=k*Math.PI*2/8;game.projectiles.push({x:p.x,y:p.y,vx:Math.cos(a)*6,vy:Math.sin(a)*6,r:10,color:'#cc0044',dmg:Math.floor(p.atk*2),owner:'player',life:70});}}
  }
}

function doHit(e,dmg,p){
  if(!e.alive)return;
  let d=dmg;
  if(p.perks.includes('shield'))d=Math.floor(d); // placeholder — shield reduces incoming, not outgoing
  e.hp-=d;e.hurtFlash=5;p.totalDmg+=d;
  if(p.perks.includes('vamp'))p.hp=Math.min(p.maxHp,p.hp+Math.floor(d*.15));
  const r=canvas.getBoundingClientRect();
  const col=p.combo>=5?'#ff8800':p.combo>=3?'#ffdd00':'#ffffff';
  spawnDmgNum(r.left+e.x,r.top+e.y-e.size,d,col);
  if(e.hp<=0)killEnemy(e,p);
}

function killEnemy(e,p){
  e.alive=false;burst(e.x,e.y,e.color,18,4,5);burst(e.x,e.y,'#ffffff',5,3,3);
  p.xp+=e.xp;p.kills++;p.totalKills++;game.kills++;
  checkLevelUp(p);checkWave();
}

function checkLevelUp(p){
  while(p.xp>=p.xpNext){p.xp-=p.xpNext;p.xpNext=Math.floor(p.xpNext*1.42);p.level++;
    burst(p.x,p.y,'#ffd700',28,6,6);showWaveAnn(`✦ LEVEL ${p.level}!`);
    setTimeout(()=>showSkillOverlay(p),660);}
}

function checkWave(){
  if(game.kills>=game.nextWaveKills){
    game.wave++;game.nextWaveKills+=Math.floor(9+game.wave*2.5);
    game.spawnInterval=Math.max(36,game.spawnInterval-8);
    showWaveAnn(`⚔ WAVE ${game.wave}`);
    game.player.hp=Math.min(game.player.maxHp,game.player.hp+22);
    checkWaveUnlocks(game.wave, game.player);
  }
}

function showWaveAnn(txt){
  const el=document.getElementById('wave-announce');el.textContent=txt;el.style.display='block';
  el.style.animation='none';el.offsetHeight;el.style.animation='waveAnn 2s forwards';
  setTimeout(()=>el.style.display='none',2000);
}

// ── UPDATE ─────────────────────────────────────────────────
function update(){
  if(pendingLevelUp)return;
  const p=game.player;
  let mx=0,my=0;
  if(keys['ArrowLeft']||keys['KeyA'])mx-=1;
  if(keys['ArrowRight']||keys['KeyD'])mx+=1;
  if(keys['ArrowUp']||keys['KeyW'])my-=1;
  if(keys['ArrowDown']||keys['KeyS'])my+=1;
  if(mx!==0)p.facing=mx>0?1:-1;

  if(p.dashDur>0){
    p.x+=p.dashVx;p.y+=p.dashVy;p.dashDur--;
    p.trail.unshift({x:p.x,y:p.y,a:1});
    p.trail=p.trail.slice(0,9).map(t=>({...t,a:t.a*.68}));
    if(p.dashDur===0&&p._dashAtk){p._dashAtk=false;
      game.enemies.forEach(e=>{if(e.alive&&Math.hypot(e.x-p.x,e.y-p.y)<62)doHit(e,Math.floor(p.atk*1.5),p);});
      burst(p.x,p.y,'#00ffe7',14,4,4);}
  }else{
    p.vx=mx*p.speed;p.vy=my*p.speed;
    if(mx&&my){p.vx*=.707;p.vy*=.707;}
    p.x+=p.vx;p.y+=p.vy;p.trail=[];
  }
  p.x=Math.max(p.w/2,Math.min(W-p.w/2,p.x));
  p.y=Math.max(p.h/2,Math.min(H-p.h/2,p.y));

  if(mouseDown&&p.atkReady)tryAttack(p);
  if(p.atkTimer>0){p.atkTimer--;if(!p.atkTimer)p.attacking=false;}
  if(p.comboTimer>0){p.comboTimer--;if(!p.comboTimer)p.combo=0;}
  if(p.invincible>0)p.invincible--;
  p.mp=Math.min(p.maxMp,p.mp+p.mpRegen);
  if(!mx){const dx=mouseX-p.x;if(Math.abs(dx)>10)p.facing=dx>0?1:-1;}

  // cooldown UI
  p.abilities.forEach((ab,i)=>{
    if(!ab.ready){ab.timer--;
      const btn=document.getElementById('ab'+i),cd=document.getElementById('ab'+i+'-cd');
      if(ab.timer<=0){ab.ready=true;ab.timer=0;btn.className='ab-btn ready';cd.textContent='';}
      else{btn.className='ab-btn cooling';cd.textContent=Math.ceil(ab.timer/60)+'s';}}
  });

  // spawn
  game.spawnTimer++;
  if(game.spawnTimer>=game.spawnInterval){game.spawnTimer=0;
    const cnt=1+Math.floor(game.wave/3);for(let i=0;i<cnt;i++)game.enemies.push(spawnEnemy(game.wave));}

  // enemies
  game.enemies.forEach(e=>{
    if(!e.alive)return;
    e.wobble+=.09;
    const dx=p.x-e.x,dy=p.y-e.y,dist=Math.hypot(dx,dy)||1;
    e.vx=dx/dist*e.spd;e.vy=dy/dist*e.spd;e.x+=e.vx;e.y+=e.vy;
    if(dist<e.range+p.w/2){e.atkTimer++;
      if(e.atkTimer>=e.atkCooldown){e.atkTimer=0;
        if(p.invincible<=0){
          let dmg=e.atk;if(p.perks.includes('shield'))dmg=Math.floor(dmg*.8);
          p.hp=Math.max(0,p.hp-dmg);p.hurtFlash=8;burst(p.x,p.y,'#ff0033',7,3,4);
          const r=canvas.getBoundingClientRect();spawnDmgNum(r.left+p.x,r.top+p.y-24,dmg,'#ff4444');
          if(p.hp<=0){endGame();return;}}}}
  });

  // projectiles
  game.projectiles.forEach(pr=>{pr.x+=pr.vx;pr.y+=pr.vy;pr.life--;
    if(pr.owner==='player'){game.enemies.forEach(e=>{if(!e.alive)return;if(Math.hypot(e.x-pr.x,e.y-pr.y)<e.size/2+pr.r){doHit(e,pr.dmg,p);pr.life=0;}});}
  });
  game.projectiles=game.projectiles.filter(pr=>pr.life>0&&pr.x>-70&&pr.x<W+70&&pr.y>-70&&pr.y<H+70);
  game.enemies=game.enemies.filter(e=>e.alive);

  updateHUD(p);
}

function updateHUD(p){
  document.getElementById('hp-bar').style.width=(p.hp/p.maxHp*100)+'%';
  document.getElementById('hp-val').textContent=Math.ceil(p.hp)+'/'+p.maxHp;
  document.getElementById('mp-bar').style.width=(p.mp/p.maxMp*100)+'%';
  document.getElementById('mp-val').textContent=Math.floor(p.mp)+'/'+p.maxMp;
  document.getElementById('xp-bar').style.width=(p.xp/p.xpNext*100)+'%';
  document.getElementById('xp-val').textContent=p.xp+'/'+p.xpNext;
  document.getElementById('lv-val').textContent=p.level;
  document.getElementById('wave-val').textContent=game.wave;
  document.getElementById('kills-val').textContent=game.kills;
  const cd=document.getElementById('combo-disp');
  cd.textContent=p.combo>=2?`${p.combo}× COMBO`:'';
}

// ── DRAW ───────────────────────────────────────────────────
function drawBg(){
  const bg=ctx.createRadialGradient(W/2,H/2,40,W/2,H/2,W*.85);
  bg.addColorStop(0,'#0d001a');bg.addColorStop(1,'#050009');
  ctx.fillStyle=bg;ctx.fillRect(0,0,W,H);
  ctx.save();ctx.globalAlpha=.032;ctx.strokeStyle='#8855ff';ctx.lineWidth=1;
  for(let x=0;x<W;x+=44){ctx.beginPath();ctx.moveTo(x,0);ctx.lineTo(x,H);ctx.stroke();}
  for(let y=0;y<H;y+=44){ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(W,y);ctx.stroke();}
  ctx.restore();
  const vig=ctx.createRadialGradient(W/2,H/2,H*.25,W/2,H/2,H*.85);
  vig.addColorStop(0,'transparent');vig.addColorStop(1,'#00000099');
  ctx.fillStyle=vig;ctx.fillRect(0,0,W,H);
}

function drawPlayer(p){
  // dash trail
  p.trail.forEach(t=>{ctx.save();ctx.globalAlpha=t.a*.28;ctx.fillStyle='#00ffe7';ctx.fillRect(t.x-p.w/2,t.y-p.h/2,p.w,p.h);ctx.restore();});
  // shadow
  ctx.save();ctx.globalAlpha=.2;ctx.fillStyle='#000';ctx.beginPath();ctx.ellipse(p.x,p.y+p.h/2,p.w/2,5,0,0,Math.PI*2);ctx.fill();ctx.restore();
  // hurt
  if(p.hurtFlash>0){ctx.save();ctx.globalAlpha=.5;ctx.fillStyle='#ff0033';ctx.fillRect(p.x-p.w/2,p.y-p.h/2,p.w,p.h);ctx.restore();p.hurtFlash--;}
  // body
  const g=ctx.createLinearGradient(p.x-p.w/2,p.y-p.h/2,p.x+p.w/2,p.y+p.h/2);
  g.addColorStop(0,'#5533ff');g.addColorStop(1,'#ff3300');
  ctx.save();ctx.shadowBlur=16;ctx.shadowColor='#7755ffaa';
  ctx.beginPath();ctx.roundRect(p.x-p.w/2,p.y-p.h/2,p.w,p.h,6);
  ctx.fillStyle=g;ctx.fill();ctx.strokeStyle='#ffffff33';ctx.lineWidth=1.5;ctx.stroke();ctx.restore();
  // aim indicator
  const{nx,ny}=aimDir(p);
  ctx.save();ctx.globalAlpha=.14;ctx.strokeStyle='#fff';ctx.lineWidth=1;ctx.setLineDash([4,8]);
  ctx.beginPath();ctx.moveTo(p.x,p.y);ctx.lineTo(p.x+nx*44,p.y+ny*44);ctx.stroke();ctx.restore();
  // attack star
  if(p.attacking){ctx.save();ctx.globalAlpha=.72;ctx.fillStyle='#ffdd00';ctx.shadowBlur=14;ctx.shadowColor='#ffdd00';
    ctx.beginPath();for(let k=0;k<5;k++){const a=Math.atan2(ny,nx)+k*Math.PI*2/5-Math.PI/2,r=k%2===0?22:10;k===0?ctx.moveTo(p.x+nx*36+Math.cos(a)*r,p.y+ny*36+Math.sin(a)*r):ctx.lineTo(p.x+nx*36+Math.cos(a)*r,p.y+ny*36+Math.sin(a)*r);}
    ctx.closePath();ctx.fill();ctx.restore();}
}

function drawEnemy(e){
  if(!e.alive)return;
  const wb=Math.sin(e.wobble)*2.2;
  const flash=e.hurtFlash>0;
  // shadow
  ctx.save();ctx.globalAlpha=.18;ctx.fillStyle='#000';ctx.beginPath();ctx.ellipse(e.x,e.y+e.size/2,e.size*.45,4,0,0,Math.PI*2);ctx.fill();ctx.restore();
  // draw by type
  ETYPES[e.typeIdx].draw(ctx,e.x,e.y+wb,e.size/2,flash);
  if(flash)e.hurtFlash--;
  // hp bar
  const bw=e.size*1.4;
  ctx.fillStyle='#ffffff12';ctx.fillRect(e.x-bw/2,e.y-e.size/2-10,bw,4);
  ctx.fillStyle=e.hp/e.maxHp>.5?'#22ff88':'#ff4422';
  ctx.fillRect(e.x-bw/2,e.y-e.size/2-10,bw*(e.hp/e.maxHp),4);
}

function drawProjectile(pr){
  ctx.save();ctx.shadowBlur=20;ctx.shadowColor=pr.color;ctx.fillStyle=pr.color;
  ctx.beginPath();ctx.arc(pr.x,pr.y,pr.r,0,Math.PI*2);ctx.fill();ctx.restore();
}

function drawParticles(){
  game.particles.forEach(p=>{ctx.save();ctx.globalAlpha=p.life;ctx.fillStyle=p.color;ctx.shadowBlur=7;ctx.shadowColor=p.color;ctx.beginPath();ctx.arc(p.x,p.y,p.size,0,Math.PI*2);ctx.fill();ctx.restore();p.x+=p.vx;p.y+=p.vy;p.vx*=.92;p.vy*=.92;p.life-=p.decay;});
  game.particles=game.particles.filter(p=>p.life>0);
}

function draw(){
  ctx.clearRect(0,0,W,H);drawBg();drawParticles();
  game.enemies.forEach(drawEnemy);drawPlayer(game.player);game.projectiles.forEach(drawProjectile);
}

function loop(){if(!game||!game.running)return;update();draw();game.animFrame=requestAnimationFrame(loop);}

// ── FLOW ───────────────────────────────────────────────────
function startGame(){
  const ts=document.getElementById('title-screen');ts.style.opacity=0;
  setTimeout(()=>{
    ts.style.display='none';
    document.getElementById('game-layout').style.display='flex';
    renderSvgButtons();resize();
    game=createGame();renderUnlockList(1);
    showWaveAnn('⚔ WAVE 1');requestAnimationFrame(loop);
  },820);
}

function endGame(){
  game.running=false;cancelAnimationFrame(game.animFrame);const p=game.player;
  document.getElementById('end-sub').textContent='YOU HAVE FALLEN — WAVE '+game.wave;
  document.getElementById('end-stats').innerHTML=`
    <div class="stat-pill"><b>${game.wave}</b><span>MAX WAVE</span></div>
    <div class="stat-pill"><b>${p.level}</b><span>LEVEL</span></div>
    <div class="stat-pill"><b>${game.kills}</b><span>KILLS</span></div>
    <div class="stat-pill"><b>${p.totalDmg}</b><span>DMG DEALT</span></div>
    <div class="stat-pill"><b>${waveUnlocksDone.size}</b><span>UNLOCKS</span></div>`;
  document.getElementById('end-overlay').style.display='flex';
}

function restartGame(){
  document.getElementById('end-overlay').style.display='none';
  document.getElementById('skill-overlay').style.display='none';
  pendingLevelUp=false;
  if(game&&game.animFrame)cancelAnimationFrame(game.animFrame);
  resize();game=createGame();renderUnlockList(1);
  showWaveAnn('⚔ WAVE 1');requestAnimationFrame(loop);
}

window.addEventListener('resize',()=>{if(game)resize();});
renderSvgButtons(); // for title screen
</script>
