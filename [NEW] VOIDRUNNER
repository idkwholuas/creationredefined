function buildChars(){
  var row=document.getElementById('char-row');row.innerHTML='';
  CHARS.forEach(function(ch){
    var d=document.createElement('div');d.className='cc'+(selChar.id===ch.id?' sel':'');
    var bars=['SPD','ATK','DEF','SHD'].map(function(l,i){var v=ch.st[i];return'<div style="display:flex;justify-content:space-between;font-size:9px;color:#222;margin-top:3px"><span>'+l+'</span><span>'+v+'/6</span></div><div class="sb"><div class="sf" style="width:'+Math.round(v/6*100)+'%;background:'+ch.c+'"></div></div>';}).join('');
    d.innerHTML='<div class="ce">'+ch.e+'</div><div class="cn">'+ch.name+'</div><div class="cr">'+ch.role+'</div>'+bars+'<div class="cd2">'+ch.desc+'</div>';
    d.onclick=function(){selChar=ch;buildChars();};
    row.appendChild(d);
  });
}
buildChars();

function buildTrophies(){
  var g=document.getElementById('tg');g.innerHTML='';
  trophies.forEach(function(t){
    var d=document.createElement('div');d.className='ti'+(t.got?' got':' lock');
    d.innerHTML='<div class="tic">'+t.icon+'</div><div class="tn">'+t.name+'</div><div class="td">'+t.desc+'</div>';
    g.appendChild(d);
  });
}

// ── START RUN ──────────────────────────────────────────
function startRun(){
  usedChars[selChar.id]=true;
  if(Object.keys(usedChars).length>=6)awardTrophy('t_all');
  runTrophies=[];
  UPG={dmg:0,fr:0,spd:0,hp:0,sh:0,cd:0,xp:0,mg:0,nr:0,cr:0};
  initGame();
  SCRIDS.forEach(function(s){var el=document.getElementById(s);if(el)el.style.display='none';});
  document.getElementById('hud').style.display='flex';
  document.getElementById('ab-row').style.display='flex';
  document.getElementById('boss-hud').style.display='none';
  updateAbIcons();
  running=true;lastT=0;
  rafId=requestAnimationFrame(gameLoop);
}

function dm(){return diff==='ultra'?3.0:diff==='nightmare'?1.9:diff==='hard'?1.45:1;}

function initGame(){
  score=0;wave=1;combo=0;comboT=0;shootT=0;frame=0;
  bossActive=false;boss=null;shake=0;
  ghostT=0;shieldT=0;slowT=0;overT=0;shadowT=0;radT=0;lockOn=0;
  abT=[0,0,0,0];tmpWpnT=0;activeWpn=selChar.wpn;
  totalKills=0;runStart=Date.now();
  noHitWave=true;bossNoHit=true;
  waveTotal=0;waveSpawned=0;waveDone=false;
  pilotLv=1;pilotXP=0;pilotXPneed=100;
  P={x:W/2,y:H*0.72,hp:selChar.hp+UPG.hp*35,maxHp:selChar.hp+UPG.hp*35,sh:selChar.sh+UPG.sh*25,maxSh:selChar.sh+UPG.sh*25,spd:selChar.spd+UPG.spd*0.5,inv:0,trail:[],col:selChar.c};
  bullets.length=0;enemies.length=0;parts.length=0;pickups.length=0;
  initStars();updateHUD();spawnWave();
}

function initStars(){
  stars=[];
  for(var i=0;i<130;i++)stars.push({x:Math.random()*W,y:Math.random()*H,r:Math.random()*1.2+0.3,spd:Math.random()*0.4+0.1,a:Math.random()*0.55+0.2,tw:Math.random()*6.28});
}

// ── WAVES ──────────────────────────────────────────────
function spawnWave(){
  noHitWave=true;waveSpawned=0;waveDone=false;
  if(wave%5===0){startBoss();return;}
  var base=4+wave*2;
  var bonus=diff==='ultra'?wave*4:diff==='nightmare'?wave*3:diff==='hard'?Math.ceil(wave*1.5):0;
  waveTotal=Math.min(base+bonus,60);
  var spawned=0;
  var delay=Math.max(100,350-wave*13);
  clearInterval(waveIv);
  waveIv=setInterval(function(){
    if(!running||spawned>=waveTotal){clearInterval(waveIv);return;}
    doSpawnEnemy();spawned++;waveSpawned=spawned;
  },delay);
}

var ECFG={
  drone:{hp:1,sz:11,spd:1.1,c:'#9966ff',pts:10,xp:5},
  bomber:{hp:3,sz:18,spd:0.65,c:'#ff5522',pts:30,xp:15},
  drifter:{hp:1,sz:10,spd:1.6,c:'#22ffcc',pts:20,xp:10},
  splitter:{hp:2,sz:15,spd:0.85,c:'#ffaa22',pts:25,xp:12},
  seeker:{hp:1,sz:11,spd:2.0,c:'#ff44aa',pts:35,xp:18},
  razor:{hp:2,sz:13,spd:1.7,c:'#44ffff',pts:28,xp:14},
  swarm:{hp:1,sz:7,spd:2.3,c:'#ff8800',pts:15,xp:8},
  armored:{hp:6,sz:20,spd:0.55,c:'#aaaaaa',pts:50,xp:25},
  elite:{hp:4,sz:14,spd:1.9,c:'#ff2266',pts:60,xp:30},
};
function doSpawnEnemy(){
  var side=Math.random()*4|0,x,y;
  if(side===0){x=Math.random()*W;y=-40;}else if(side===1){x=W+40;y=Math.random()*H;}else if(side===2){x=Math.random()*W;y=H+40;}else{x=-40;y=Math.random()*H;}
  var w=wave,d=dm();
  var pool=w<3?['drone']:w<5?['drone','drifter']:w<7?['drone','bomber','drifter','splitter']:w<10?['drone','bomber','drifter','splitter','seeker','razor']:['drone','bomber','drifter','splitter','seeker','razor','swarm','armored','elite'];
  var type=pool[Math.random()*pool.length|0];
  var cfg=ECFG[type];
  var um=diff==='ultra'?2:diff==='nightmare'?1.5:1;
  var hp=Math.max(1,Math.round(cfg.hp*d*um));
  enemies.push({x:x,y:y,type:type,hp:hp,maxHp:hp,spd:cfg.spd*(1+w*0.08)*d,sz:cfg.sz,c:cfg.c,pts:cfg.pts,xp:cfg.xp,ang:0,ph:Math.random()*6.28,vx:0,vy:0,slow:0,marked:false});
}

function startBoss(){
  bossActive=true;bossNoHit=true;
  document.getElementById('boss-hud').style.display='block';
  var d=dm(),w=wave;
  var idx=Math.min(Math.floor(w/5)-1,2);
  var defs=[
    {name:'RIFT ENTITY',c:'#cc44ff',hp:Math.round((120+w*40)*d),sz:40,pts:3000,tid:'t_b1',ph:'spiral'},
    {name:'ABYSS TITAN',c:'#ff2244',hp:Math.round((200+w*60)*d),sz:58,pts:7000,tid:'t_b2',ph:'charge'},
    {name:'VOID HERALD',c:'#ffaa00',hp:Math.round((300+w*80)*d),sz:52,pts:12000,tid:'t_b3',ph:'tele'},
  ];
  var bd=defs[idx];
  boss={name:bd.name,c:bd.c,hp:bd.hp,maxHp:bd.hp,sz:bd.sz,pts:bd.pts,tid:bd.tid,ph:bd.ph,x:W/2,y:-90,vx:0,vy:0,ang:0,stimer:0,ptimer:0};
  document.getElementById('boss-lbl').textContent=bd.name;
  document.getElementById('boss-bar').style.width='100%';
}

// ── GAME LOOP ──────────────────────────────────────────
function gameLoop(ts){
  if(!running){rafId=requestAnimationFrame(gameLoop);return;}
  var dt=Math.min((ts-lastT)/16.67,3);lastT=ts;frame++;
  update(dt);render();
  rafId=requestAnimationFrame(gameLoop);
}

function update(){
  if(shake>0)shake--;
  if(ghostT>0)ghostT--;if(shieldT>0)shieldT--;if(slowT>0)slowT--;
  if(overT>0)overT--;if(shadowT>0)shadowT--;if(radT>0)radT--;if(lockOn>0)lockOn--;
  if(tmpWpnT>0){tmpWpnT--;if(!tmpWpnT){activeWpn=selChar.wpn;document.getElementById('wpn-name').textContent=WPNS[activeWpn].name;}}
  for(var i=0;i<4;i++)if(abT[i]>0)abT[i]--;
  if(comboT>0){comboT--;if(!comboT){combo=0;document.getElementById('combo-txt').textContent='';}}

  // Player move
  var spd2=P.spd*(overT>0?1.7:1);
  var dx=(keys['ArrowLeft']||keys['a']||keys['A']?-1:0)+(keys['ArrowRight']||keys['d']||keys['D']?1:0);
  var dy=(keys['ArrowUp']||keys['w']||keys['W']?-1:0)+(keys['ArrowDown']||keys['s']||keys['S']?1:0);
  if(dx||dy){var l=Math.sqrt(dx*dx+dy*dy);P.x=Math.max(16,Math.min(W-16,P.x+dx/l*spd2));P.y=Math.max(16,Math.min(H-16,P.y+dy/l*spd2));}
  P.trail.unshift({x:P.x,y:P.y});if(P.trail.length>10)P.trail.pop();
  if(P.inv>0)P.inv--;
  if(P.sh<P.maxSh&&frame%90===0)P.sh=Math.min(P.maxSh,P.sh+1);

  // Shoot
  var wd=WPNS[activeWpn];
  var fr=Math.max(3,Math.round(wd.fr/(1+UPG.fr*0.2))*(overT>0?0.55:1));
  if(++shootT>=fr){
    shootT=0;
    if(bullets.length<120){
      var ang=Math.atan2(my-P.y,mx-P.x);
      for(var i=0;i<wd.multi;i++){
        var a=ang;
        if(wd.multi===2)a+=i===0?-0.16:0.16;
        if(wd.multi===5)a+=(i-2)*0.22;
        if(wd.multi===3)a+=(i-1)*0.28;
        var cdmg=Math.random()<UPG.cr*0.12?3:1;
        var dmg2=wd.dmg*(1+UPG.dmg*0.3)*cdmg*(lockOn>0?8:1)*(shadowT>0?3:1);
        bullets.push({x:P.x,y:P.y,vx:Math.cos(a)*wd.spd,vy:Math.sin(a)*wd.spd,life:90,sz:wd.sz,c:wd.c,dmg:dmg2,pierce:wd.pierce,homing:wd.homing});
      }
    }
  }

  // Bullets
  var sl=slowT>0?0.28:1;
  for(var i=bullets.length-1;i>=0;i--){
    var b=bullets[i];
    if(b.homing){var t=enemies[0]||boss;if(t){var ba=Math.atan2(t.y-b.y,t.x-b.x);b.vx+=(Math.cos(ba)*0.5-b.vx)*0.09;b.vy+=(Math.sin(ba)*0.5-b.vy)*0.09;}}
    b.x+=b.vx;b.y+=b.vy;b.life--;
    if(b.life<=0||b.x<-20||b.x>W+20||b.y<-20||b.y>H+20){bullets.splice(i,1);}
  }

  // Enemies
  for(var i=enemies.length-1;i>=0;i--){
    var e=enemies[i];
    if(e.slow>0)e.slow--;
    var s=e.spd*sl*(e.slow>0?0.22:1);
    e.ang+=0.045*sl;
    var ba=Math.atan2(P.y-e.y,P.x-e.x);
    if(e.type==='drifter'){e.ph+=0.055*sl;e.x+=(Math.cos(ba)*s+Math.cos(e.ph)*2.4)*sl;e.y+=(Math.sin(ba)*s+Math.sin(e.ph)*2.4)*sl;}
    else if(e.type==='seeker'){var dd=Math.hypot(P.x-e.x,P.y-e.y);var acc=s*(dd<160?2.3:1);e.x+=Math.cos(ba)*acc;e.y+=Math.sin(ba)*acc;}
    else if(e.type==='razor'){e.ph+=0.03*sl;e.x+=Math.cos(ba+Math.sin(e.ph)*0.9)*s;e.y+=Math.sin(ba+Math.sin(e.ph)*0.9)*s;}
    else if(e.type==='swarm'){e.ph+=0.07*sl;e.x+=Math.cos(ba)*s+Math.cos(e.ph)*0.7;e.y+=Math.sin(ba)*s+Math.sin(e.ph)*0.7;}
    else if(e.type==='elite'){e.ph+=0.025*sl;e.x+=(Math.cos(ba)*s+Math.cos(e.ph)*1.5)*sl;e.y+=(Math.sin(ba)*s+Math.sin(e.ph)*1.5)*sl;}
    else{e.x+=Math.cos(ba)*s;e.y+=Math.sin(ba)*s;}
    if(e.x<-250||e.x>W+250||e.y<-250||e.y>H+250)enemies.splice(i,1);
  }

  // Boss
  if(boss){
    boss.ang+=0.022;boss.ptimer+=1;boss.stimer+=1;
    var ba=Math.atan2(P.y-boss.y,P.x-boss.x);
    if(boss.ph==='spiral'){boss.x+=Math.cos(ba)*1.5*sl;boss.y+=Math.sin(ba)*1.5*sl;}
    else if(boss.ph==='charge'){
      if(boss.ptimer%150<20){boss.vx+=Math.cos(ba)*1.1;boss.vy+=Math.sin(ba)*1.1;}else{boss.vx*=0.90;boss.vy*=0.90;}
      boss.x+=boss.vx*sl;boss.y+=boss.vy*sl;
    }else{
      if(boss.ptimer%180===1){boss.x=W*0.15+Math.random()*W*0.7;boss.y=H*0.08+Math.random()*H*0.42;addParts(boss.x,boss.y,boss.c,18);}
      boss.x+=Math.cos(ba)*1.0*sl;boss.y+=Math.sin(ba)*1.0*sl;
    }
    boss.x=Math.max(boss.sz,Math.min(W-boss.sz,boss.x));boss.y=Math.max(boss.sz,Math.min(H*0.6,boss.y));
    var bfr=diff==='ultra'?25:diff==='nightmare'?35:Math.max(40,90-wave*2);
    if(boss.stimer>=bfr&&enemies.length<45){
      boss.stimer=0;
      var n=3+Math.floor(wave*0.35);
      for(var i=0;i<n;i++){var a=(i/n)*6.28+boss.ang;enemies.push({x:boss.x+Math.cos(a)*boss.sz,y:boss.y+Math.sin(a)*boss.sz,type:'drone',hp:1,maxHp:1,spd:1.2+wave*0.06,sz:9,c:boss.c,pts:5,xp:3,ang:0,ph:0,vx:0,vy:0,slow:0,marked:false});}
    }
    document.getElementById('boss-bar').style.width=(boss.hp/boss.maxHp*100)+'%';
  }

  // Bullet-enemy hits
  outer:for(var bi=bullets.length-1;bi>=0;bi--){
    var b=bullets[bi];if(!b)continue;
    for(var ei=enemies.length-1;ei>=0;ei--){
      var e=enemies[ei];
      if(Math.hypot(b.x-e.x,b.y-e.y)<e.sz+b.sz){
        e.hp-=b.dmg;addParts(b.x,b.y,e.c,3);
        if(!b.pierce)bullets.splice(bi,1);
        if(e.hp<=0)killEnemy(e,ei);
        if(!b.pierce)continue outer;
      }
    }
  }
  // Bullet-boss hits
  if(boss){
    for(var bi=bullets.length-1;bi>=0;bi--){
      var b=bullets[bi];if(!b)continue;
      if(Math.hypot(b.x-boss.x,b.y-boss.y)<boss.sz+b.sz){
        boss.hp-=b.dmg;addParts(b.x,b.y,boss.c,5);
        if(!b.pierce)bullets.splice(bi,1);
        if(boss.hp<=0)killBoss();
        break;
      }
    }
  }

  // Player-enemy hits
  if(!P.inv&&!ghostT){
    for(var ei=enemies.length-1;ei>=0;ei--){
      var e=enemies[ei];
      if(Math.hypot(e.x-P.x,e.y-P.y)<e.sz+13){
        var dmgMap={bomber:45,seeker:30,armored:35,elite:40,splitter:22,razor:22,swarm:10,drone:15,drifter:12};
        hitPlayer(dmgMap[e.type]||15,ei);break;
      }
    }
    if(boss&&Math.hypot(boss.x-P.x,boss.y-P.y)<boss.sz+14)hitPlayer(60,-1);
  }

  // Radiance
  if(radT>0&&frame%18===0){
    var nr=1+(UPG.nr||0)*0.4;
    for(var ei=enemies.length-1;ei>=0;ei--){
      if(Math.hypot(enemies[ei].x-P.x,enemies[ei].y-P.y)<160*nr){enemies[ei].hp-=1;if(enemies[ei].hp<=0)killEnemy(enemies[ei],ei);}
    }
  }

  // Pickups
  var pr=16*(1+(UPG.mg||0)*0.35);
  for(var i=pickups.length-1;i>=0;i--){
    var p=pickups[i];p.y+=p.vy;p.vy+=0.02;p.life--;p.ang+=0.045;
    if(Math.hypot(p.x-P.x,p.y-P.y)<pr){collectPickup(p);pickups.splice(i,1);continue;}
    if(p.life<=0||p.y>H+20)pickups.splice(i,1);
  }

  // Particles
  for(var i=parts.length-1;i>=0;i--){
    var p=parts[i];p.x+=p.vx;p.y+=p.vy;p.life--;p.vx*=0.91;p.vy*=0.91;
    if(p.life<=0)parts.splice(i,1);
  }

  // Stars
  for(var i=0;i<stars.length;i++){var s=stars[i];s.y+=s.spd*(1+wave*0.025)*sl;s.tw+=0.03;if(s.y>H+2){s.y=-2;s.x=Math.random()*W;}}

  // Wave complete
  if(!bossActive&&!waveDone&&waveSpawned>=waveTotal&&waveTotal>0&&enemies.length===0){
    waveDone=true;
    if(noHitWave)awardTrophy('t_nodmg');
    setTimeout(function(){if(running){wave++;updateHUD();spawnWave();}},1800);
  }

  if(Date.now()-runStart>300000)awardTrophy('t_5min');
  updateHUD();updateAbCD();
}

function hitPlayer(dmg,ei){
  noHitWave=false;bossNoHit=false;
  if(shieldT>0)return;
  var r=dmg;
  if(P.sh>0){var a=Math.min(P.sh,r);P.sh-=a;r-=a;}
  if(r>0)P.hp-=r;
  P.inv=55;shake=16;
  var df=document.getElementById('dmg');df.style.display='block';setTimeout(function(){df.style.display='none';},160);
  combo=0;comboT=0;document.getElementById('combo-txt').textContent='';
  if(ei>=0)enemies.splice(ei,1);
  if(P.hp<=0){P.hp=0;gameOver();}
}

function killEnemy(e,ei){
  combo++;comboT=165;totalKills++;
  var mult=diff==='ultra'?2.2:diff==='nightmare'?1.7:diff==='hard'?1.3:1;
  var pts=Math.round(e.pts*(1+combo*0.13)*mult);
  score+=pts;
  var xpg=Math.round((e.xp||5)*(1+(UPG.xp||0)*0.4));
  addXP(xpg);
  explode(e.x,e.y,e.c,e.type);
  maybePickup(e.x,e.y);
  if(e.type==='splitter'&&e.sz>8){
    for(var s=0;s<3;s++){var a=Math.random()*6.28;enemies.push({x:e.x+Math.cos(a)*12,y:e.y+Math.sin(a)*12,type:'drone',hp:1,maxHp:1,spd:e.spd*1.5,sz:6,c:'#ffcc22',pts:6,xp:3,ang:0,ph:0,vx:0,vy:0,slow:0,marked:false});}
  }
  enemies.splice(ei,1);
  if(combo>1)addKF(e.type,combo);
  if(totalKills===1)awardTrophy('t_first');
  if(combo>=10)awardTrophy('t_c10');if(combo>=25)awardTrophy('t_c25');if(combo>=50)awardTrophy('t_c50');
  if(score>=50000)awardTrophy('t_s50k');if(score>=200000)awardTrophy('t_s200k');if(score>=1000000)awardTrophy('t_s1m');
  if(wave>=5)awardTrophy('t_w5');if(wave>=10)awardTrophy('t_w10');if(wave>=20)awardTrophy('t_w20');if(wave>=30)awardTrophy('t_w30');
  if(totalKills>=1000)awardTrophy('t_1k');
  if(combo>=3){var lbl=combo>=50?'TRANSCENDENT':combo>=25?'GODLIKE':combo>=10?'ANNIHILATE':combo>=5?'MASSACRE':'COMBO';document.getElementById('combo-txt').textContent='x'+combo+' '+lbl;}
}

function killBoss(){
  var mult=diff==='ultra'?2.2:diff==='nightmare'?1.7:1;
  score+=Math.round(boss.pts*mult);
  explode(boss.x,boss.y,boss.c,'boss');shake=35;
  if(boss.tid)awardTrophy(boss.tid);
  if(bossNoHit)awardTrophy('t_pfb');
  if(wave>=10&&diff==='ultra')awardTrophy('t_ultra');
  boss=null;bossActive=false;
  // Clear all boss minions so the next wave isn't blocked
  enemies.length=0;
  document.getElementById('boss-hud').style.display='none';
  setTimeout(function(){if(running){wave++;updateHUD();spawnWave();}},2800);
}

function addXP(n){
  pilotXP+=n;
  if(pilotXP>=pilotXPneed){
    pilotXP-=pilotXPneed;pilotLv++;pilotXPneed=Math.round(pilotXPneed*1.35);
    if(pilotLv>=10)awardTrophy('t_lv10');if(pilotLv>=20)awardTrophy('t_lv20');
    showUpgradeScreen();
  }
  document.getElementById('xp-fill').style.width=Math.round(pilotXP/pilotXPneed*100)+'%';
  document.getElementById('lv-txt').textContent='LV'+pilotLv;
}

function showUpgradeScreen(){
  running=false;cancelAnimationFrame(rafId);
  SCRIDS.forEach(function(s){var el=document.getElementById(s);if(el)el.style.display='none';});
  document.getElementById('sc-upg').style.display='flex';
  document.getElementById('hud').style.display='none';
  document.getElementById('ab-row').style.display='none';
  var pool=UPGRADES.slice(),picks=[];
  for(var i=0;i<3;i++){var idx=Math.floor(Math.random()*pool.length);picks.push(pool.splice(idx,1)[0]);}
  var cards=document.getElementById('upg-cards');cards.innerHTML='';
  picks.forEach(function(u){
    var d=document.createElement('div');d.className='uc';
    d.innerHTML='<div class="ui">'+u.i+'</div><div class="un">'+u.n+'</div><div class="ud">'+u.d+'</div>';
    d.onclick=function(){pickUpgrade(u.id);};cards.appendChild(d);
  });
  var lv=document.getElementById('lvlup');
  document.getElementById('lvlup-s').textContent='PILOT LEVEL '+pilotLv;
  lv.style.display='block';setTimeout(function(){lv.style.display='none';},2200);
}

function pickUpgrade(id){
  UPG[id]=(UPG[id]||0)+1;
  if(id==='hp'){P.maxHp+=35;P.hp=Math.min(P.hp+35,P.maxHp);}
  if(id==='sh'){P.maxSh+=25;P.sh=Math.min(P.sh+25,P.maxSh);}
  if(id==='spd')P.spd+=0.5;
  SCRIDS.forEach(function(s){var el=document.getElementById(s);if(el)el.style.display='none';});
  document.getElementById('hud').style.display='flex';
  document.getElementById('ab-row').style.display='flex';
  if(boss)document.getElementById('boss-hud').style.display='block';
  running=true;lastT=0;
  rafId=requestAnimationFrame(gameLoop);
}

function maybePickup(x,y){
  if(Math.random()>0.14)return;
  var types=['hp','sh','wpn','score','slow','inv'];
  var wlist=['scatter','chain','minigun'];
  var t=types[Math.floor(Math.random()*types.length)];
  var wt=t==='wpn'?wlist[Math.floor(Math.random()*wlist.length)]:null;
  pickups.push({x:x,y:y,type:t,wt:wt,vy:-1.8,ang:0,life:300});
}

function collectPickup(p){
  if(p.type==='hp'){P.hp=Math.min(P.maxHp,P.hp+40);addParts(p.x,p.y,'#44ff88',8);}
  else if(p.type==='sh'){P.sh=Math.min(P.maxSh||50,P.sh+35);addParts(p.x,p.y,'#3366ff',8);}
  else if(p.type==='wpn'&&p.wt){
    activeWpn=p.wt;tmpWpnT=960;
    document.getElementById('wpn-name').textContent=WPNS[p.wt].name+' [15s]';
    showPickPop(WPNS[p.wt].name,'Active for 15 seconds');
    addParts(p.x,p.y,WPNS[p.wt].c,12);
    if(p.wt==='scatter')awardTrophy('t_scat');if(p.wt==='chain')awardTrophy('t_chain');if(p.wt==='minigun')awardTrophy('t_mini');
  }
  else if(p.type==='score'){score+=900+wave*60;addParts(p.x,p.y,'#ffd060',8);}
  else if(p.type==='slow'){slowT=380;addParts(p.x,p.y,'#88ffff',10);}
  else if(p.type==='inv'){P.inv=200;ghostT=200;addParts(p.x,p.y,P.col,10);}
}

function showPickPop(name,desc){
  document.getElementById('pu-name').textContent=name;document.getElementById('pu-desc').textContent=desc;
  var el=document.getElementById('pu-pop');el.style.display='block';
  clearTimeout(el._t);el._t=setTimeout(function(){el.style.display='none';},2400);
}

// ── ABILITIES ──────────────────────────────────────────
function useAb(idx){
  if(abT[idx]>0)return;
  var cd=Math.max(60,Math.round(selChar.abCD[idx]*(1-(UPG.cd||0)*0.18)));
  abT[idx]=cd;
  var nr=1+(UPG.nr||0)*0.4,id=selChar.id;

  if(id==='voidwalker'){
    if(idx===0){for(var i=0;i<18;i++){var a=(i/18)*6.28;bullets.push({x:P.x,y:P.y,vx:Math.cos(a)*13,vy:Math.sin(a)*13,life:75,sz:3.5,c:'#ff88ff',dmg:2.5*(1+UPG.dmg*0.3),pierce:false,homing:false});}}
    if(idx===1){P.inv=130;ghostT=130;addParts(P.x,P.y,P.col,14);}
    if(idx===2){overT=220;}
    if(idx===3){for(var i=0;i<enemies.length;i++){var a=Math.atan2(P.y-enemies[i].y,P.x-enemies[i].x);enemies[i].x+=Math.cos(a)*20*nr;enemies[i].y+=Math.sin(a)*20*nr;}addParts(P.x,P.y,'#aa88ff',22);}
  }
  if(id==='ironclad'){
    if(idx===0){var ang=Math.atan2(my-P.y,mx-P.x);for(var i=0;i<8;i++){var a=ang+(i-3.5)*0.14;bullets.push({x:P.x,y:P.y,vx:Math.cos(a)*12,vy:Math.sin(a)*12,life:95,sz:6,c:'#3388ff',dmg:5*(1+UPG.dmg*0.3),pierce:false,homing:true});}}
    if(idx===1){shieldT=200;addParts(P.x,P.y,'#3388ff',14);}
    if(idx===2){for(var i=0;i<enemies.length;i++){var a=Math.atan2(enemies[i].y-P.y,enemies[i].x-P.x)+Math.PI;var d=Math.hypot(enemies[i].x-P.x,enemies[i].y-P.y);enemies[i].x+=Math.cos(a)*Math.min(d,0.6)*32;enemies[i].y+=Math.sin(a)*Math.min(d,0.6)*32;}shake=18;}
    if(idx===3){for(var i=0;i<10;i++){(function(ii){setTimeout(function(){if(!running)return;var tx=P.x+(Math.random()-0.5)*320*nr,ty=P.y+(Math.random()-0.5)*320*nr;explode(tx,ty,'#3388ff','bomb');for(var ei=enemies.length-1;ei>=0;ei--){if(Math.hypot(enemies[ei].x-tx,enemies[ei].y-ty)<85*nr){enemies[ei].hp-=3;if(enemies[ei].hp<=0)killEnemy(enemies[ei],ei);}}},ii*110);})(i);}}
  }
  if(id==='phantom'){
    if(idx===0){for(var i=0;i<24;i++){var a=(i/24)*6.28;bullets.push({x:P.x,y:P.y,vx:Math.cos(a)*12,vy:Math.sin(a)*12,life:65,sz:2.5,c:'#22ffcc',dmg:1*(1+UPG.dmg*0.3),pierce:false,homing:false});}}
    if(idx===1){for(var i=0;i<enemies.length;i++)enemies[i].slow=200;slowT=200;}
    if(idx===2){ghostT=280;P.inv=280;addParts(P.x,P.y,'#22ffcc',18);}
    if(idx===3){shadowT=300;addParts(P.x,P.y,'#ff4466',12);}
  }
  if(id==='solaris'){
    if(idx===0){for(var i=0;i<enemies.length;i++)enemies[i].slow=200;addParts(W/2,H/2,'#ffff44',30);}
    if(idx===1){P.hp=Math.min(P.maxHp,P.hp+55);addParts(P.x,P.y,'#44ff88',16);}
    if(idx===2){var nr2=1+(UPG.nr||0)*0.4;for(var ei=enemies.length-1;ei>=0;ei--){if(Math.hypot(enemies[ei].x-P.x,enemies[ei].y-P.y)<210*nr2){enemies[ei].hp=0;killEnemy(enemies[ei],ei);}}shake=22;addParts(P.x,P.y,'#ffdd44',30);}
    if(idx===3){radT=280;addParts(P.x,P.y,'#ffaa22',18);}
  }
  if(id==='reaper'){
    if(idx===0){lockOn=6;addParts(P.x,P.y,'#ff4466',12);}
    if(idx===1){var dist=90,a=Math.atan2(my-P.y,mx-P.x);P.x=Math.max(16,Math.min(W-16,P.x+Math.cos(a)*dist));P.y=Math.max(16,Math.min(H-16,P.y+Math.sin(a)*dist));P.inv=45;addParts(P.x,P.y,'#ff4466',14);}
    if(idx===2){for(var i=0;i<enemies.length;i++)enemies[i].marked=true;addParts(W/2,H/2,'#ff4466',20);}
    if(idx===3){overT=220;addParts(P.x,P.y,'#ff8844',12);}
  }
  if(id==='wraith'){
    if(idx===0){for(var i=0;i<14;i++){var a=(i/14)*6.28;bullets.push({x:P.x,y:P.y,vx:Math.cos(a)*11,vy:Math.sin(a)*11,life:80,sz:3,c:'#8844cc',dmg:2*(1+UPG.dmg*0.3),pierce:false,homing:false});}}
    if(idx===1){for(var i=0;i<enemies.length;i++){var a=Math.atan2(P.y-enemies[i].y,P.x-enemies[i].x);enemies[i].x+=Math.cos(a)*28*nr;enemies[i].y+=Math.sin(a)*28*nr;}addParts(P.x,P.y,'#8844cc',20);}
    if(idx===2){slowT=220;shake=12;}
    if(idx===3){for(var i=0;i<enemies.length;i++){enemies[i].slow=240;addParts(enemies[i].x,enemies[i].y,'#8844cc',3);}}
  }
}

