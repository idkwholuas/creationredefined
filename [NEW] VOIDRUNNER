// ── PARTICLES ──────────────────────────────────────────
function addParts(x,y,c,n){
  var max=260-parts.length;n=Math.min(n,max);
  for(var i=0;i<n;i++){var a=Math.random()*6.28,s=Math.random()*3+0.8;parts.push({x:x,y:y,vx:Math.cos(a)*s,vy:Math.sin(a)*s,c:c,life:22+Math.floor(Math.random()*16),sz:2,ring:false});}
}
function explode(x,y,c,type){
  var n=type==='boss'?35:type==='bomber'||type==='bomb'?20:10;
  addParts(x,y,c,n);
  parts.push({x:x,y:y,vx:0,vy:0,c:c,life:20,maxL:20,sz:type==='boss'?52:type==='bomber'||type==='bomb'?34:22,ring:true});
}

