<style>
*{margin:0;padding:0;box-sizing:border-box}
html,body{width:100%;height:100%;overflow:hidden;background:#000;font-family:'Share Tech Mono',monospace;cursor:none}
canvas{position:absolute;top:0;left:0;display:block}
#ui{position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none}
#hud{display:none;position:absolute;top:0;left:0;width:100%;padding:10px 16px;flex-direction:row;justify-content:space-between;align-items:flex-start}
.hl{font-size:8px;letter-spacing:3px;color:#2a2a4a;text-transform:uppercase;margin-bottom:2px}
.hv{font-size:24px;font-weight:700;color:#ccd;line-height:1;font-family:'Orbitron',monospace}
#combo-txt{font-size:11px;color:#ffd060;letter-spacing:2px;min-height:14px;font-weight:700}
#mid-hud{position:absolute;top:10px;left:50%;transform:translateX(-50%);text-align:center;pointer-events:none}
#wave-v{font-size:20px;color:#7755ee;font-family:'Orbitron',monospace}
#wpn-name{font-size:9px;color:#334;letter-spacing:2px;margin-top:1px}
#lv-row{display:flex;align-items:center;gap:5px;margin-top:3px;justify-content:center}
#lv-txt{font-size:9px;color:#7755ee}
#xp-bg{width:72px;height:3px;background:#111;border-radius:2px}
#xp-fill{height:3px;background:#7755ee;border-radius:2px;width:0%;transition:width .3s}
#hp-bg{width:130px;height:5px;background:#1a1a28;border-radius:3px}
#hp-bar{height:5px;border-radius:3px;transition:width .1s,background .3s}
#sh-bg{width:130px;height:3px;background:#0a0a18;border-radius:2px;margin-top:3px}
#sh-bar{height:3px;background:#3366ff;border-radius:2px;transition:width .1s}
#char-lbl{font-size:9px;color:#7755ee;letter-spacing:1px;margin-top:3px}
#ab-row{display:none;position:absolute;bottom:16px;left:50%;transform:translateX(-50%);flex-direction:row;gap:8px}
.ab{width:46px;height:46px;border:1px solid #1a1a30;border-radius:4px;background:#07070f;position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center;font-size:18px}
.ab-k{position:absolute;top:2px;right:3px;font-size:8px;color:#333;letter-spacing:1px}
.ab-cd{position:absolute;bottom:0;left:0;width:100%;background:#fff1;transition:height .08s}
#boss-hud{display:none;position:absolute;bottom:74px;left:50%;transform:translateX(-50%);width:330px;text-align:center}
#boss-lbl{font-size:9px;letter-spacing:4px;color:#e33;margin-bottom:3px;font-family:'Orbitron',monospace}
#boss-bg{width:100%;height:6px;background:#1a0808;border-radius:3px}
#boss-bar{height:6px;border-radius:3px;background:#e33;transition:width .15s}
#notif{display:none;position:absolute;right:16px;top:70px;background:#0b0b18;border:1px solid #ffd060;border-radius:5px;padding:9px 13px;animation:nin .3s ease}
@keyframes nin{from{opacity:0;transform:translateX(24px)}to{opacity:1;transform:translateX(0)}}
#n-icon{font-size:18px;margin-bottom:2px}
#n-name{font-size:10px;color:#ffd060;letter-spacing:2px}
#n-desc{font-size:9px;color:#444;margin-top:2px}
#dmg{display:none;position:absolute;top:0;left:0;width:100%;height:100%;background:radial-gradient(ellipse at center,transparent 35%,#b00 100%)}
#cur{position:absolute;pointer-events:none;width:20px;height:20px;transform:translate(-50%,-50%)}
#kf{position:absolute;left:14px;top:72px;pointer-events:none}
.kfe{font-size:9px;color:#555;letter-spacing:1px;margin-bottom:2px}
#pu-pop{display:none;position:absolute;top:42%;left:50%;transform:translate(-50%,-50%);background:#0c0c1c;border:1px solid #55aaff;border-radius:6px;padding:13px 22px;text-align:center;pointer-events:none}
#pu-name{font-size:14px;color:#55aaff;letter-spacing:3px;font-family:'Orbitron',monospace}
#pu-desc{font-size:10px;color:#336;margin-top:3px}
#lvlup{display:none;position:absolute;top:38%;left:50%;transform:translate(-50%,-50%);text-align:center;pointer-events:none}
#lvlup-t{font-family:'Orbitron',monospace;font-size:26px;color:#ffd060;letter-spacing:5px}
#lvlup-s{font-size:11px;color:#aa88ff;letter-spacing:3px;margin-top:4px}
.scr{position:absolute;top:0;left:0;width:100%;height:100%;background:rgba(2,2,10,.97);display:none;flex-direction:column;align-items:center;justify-content:center}
#sc-menu{display:flex}
.gtitle{font-family:'Orbitron',monospace;font-size:46px;font-weight:900;color:#ccd;letter-spacing:7px}
.gsub{font-size:10px;letter-spacing:6px;color:#222;margin:5px 0 40px}
.mbtn{width:220px;padding:12px;background:transparent;border:1px solid #222;color:#555;font-family:'Share Tech Mono',monospace;font-size:11px;letter-spacing:4px;cursor:pointer;pointer-events:all;transition:all .2s;margin:4px;text-align:center;display:block}
.mbtn:hover{border-color:#7755ee;color:#ccd;background:#7755ee14}
#st-box{max-width:520px;text-align:center}
#st-title{font-size:10px;letter-spacing:5px;color:#7755ee;margin-bottom:16px;font-family:'Orbitron',monospace}
#st-body{font-size:13px;color:#666;line-height:1.95;letter-spacing:.3px}
#st-body b{color:#ccd}
.sbtn{margin-top:28px;padding:11px 38px;background:transparent;border:1px solid #7755ee;color:#9977cc;font-family:'Share Tech Mono',monospace;font-size:11px;letter-spacing:4px;cursor:pointer;pointer-events:all;transition:all .2s}
.sbtn:hover{background:#7755ee22;color:#fff}
.scrh{font-family:'Orbitron',monospace;font-size:15px;letter-spacing:5px;color:#ccd;margin-bottom:18px}
#char-row{display:flex;gap:10px;flex-wrap:wrap;justify-content:center;max-width:800px}
.cc{width:155px;border:1px solid #111;border-radius:6px;padding:13px;cursor:pointer;pointer-events:all;transition:all .2s;background:#08081a;text-align:center}
.cc:hover,.cc.sel{border-color:#7755ee;background:#111228}
.cc .ce{font-size:30px;margin-bottom:5px}
.cc .cn{font-size:11px;color:#ccd;letter-spacing:2px;font-family:'Orbitron',monospace}
.cc .cr{font-size:9px;color:#333;margin:3px 0}
.sb{height:3px;background:#0f0f1e;border-radius:2px;margin:2px 0}
.sf{height:3px;border-radius:2px}
.cd2{font-size:9px;color:#222;margin-top:7px;line-height:1.4;text-align:left}
#diff-row{display:flex;gap:8px;margin:12px 0}
.db{padding:8px 18px;border:1px solid #181828;color:#333;font-family:'Share Tech Mono',monospace;font-size:10px;letter-spacing:3px;cursor:pointer;pointer-events:all;background:transparent;transition:all .2s;border-radius:3px}
.db:hover{border-color:#7755ee;color:#aa88ff}
.db.on{border-color:#7755ee;color:#ccd;background:#7755ee1a}
.ultra{border-color:#400!important;color:#833!important}
.ultra:hover,.ultra.on{background:#40001a!important;border-color:#e33!important;color:#faa!important}
#tg{display:grid;grid-template-columns:repeat(5,1fr);gap:8px;max-width:760px;margin:14px 0;max-height:380px;overflow-y:auto}
.ti{border:1px solid #0f0f1e;border-radius:5px;padding:9px;background:#05050e;text-align:center}
.ti.got{border-color:#ffd060}
.ti .tic{font-size:20px;margin-bottom:3px}
.ti .tn{font-size:9px;color:#ffd060;letter-spacing:1px}
.ti .td{font-size:8px;color:#333;margin-top:2px;line-height:1.4}
.ti.lock .tic{filter:grayscale(1)opacity(.2)}
.ti.lock .tn{color:#1a1a1a}
#upg-title{font-family:'Orbitron',monospace;font-size:14px;letter-spacing:5px;color:#ffd060;margin-bottom:5px}
#upg-sub{font-size:10px;color:#333;letter-spacing:2px;margin-bottom:22px}
#upg-cards{display:flex;gap:12px}
.uc{width:175px;border:1px solid #1a1a28;border-radius:7px;padding:16px;cursor:pointer;pointer-events:all;background:#08081a;transition:all .2s;text-align:center}
.uc:hover{border-color:#ffd060;background:#141408}
.uc .ui{font-size:30px;margin-bottom:8px}
.uc .un{font-size:11px;color:#ffd060;letter-spacing:2px;font-family:'Orbitron',monospace}
.uc .ud{font-size:10px;color:#444;margin-top:5px;line-height:1.4}
#ov-h{font-family:'Orbitron',monospace;font-size:38px;color:#c22;letter-spacing:6px;margin-bottom:4px}
#ov-wave{font-size:10px;color:#333;letter-spacing:3px;margin-bottom:4px}
#ov-lbl{font-size:9px;color:#222;letter-spacing:3px}
#ov-score{font-size:48px;font-family:'Orbitron',monospace;color:#ccd;margin-bottom:4px}
#ov-trophies{display:flex;gap:6px;flex-wrap:wrap;justify-content:center;margin:12px 0;max-width:500px}
.nt{padding:5px 9px;background:#ffd06018;border:1px solid #ffd060;border-radius:3px;font-size:9px;color:#ffd060;letter-spacing:1px}
.br{display:flex;gap:10px;margin-top:14px}
</style>
</head>
