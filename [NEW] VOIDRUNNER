addEventListener('keydown',function(e){
  keys[e.key]=true;
  if(running){
    if(e.key==='q'||e.key==='Q')useAb(0);
    if(e.key==='e'||e.key==='E')useAb(1);
    if(e.key==='r'||e.key==='R')useAb(2);
    if(e.key==='f'||e.key==='F')useAb(3);
  }
  if(['ArrowUp','ArrowDown','ArrowLeft','ArrowRight',' '].indexOf(e.key)>=0)e.preventDefault();
});
addEventListener('keyup',function(e){keys[e.key]=false;});
addEventListener('mousemove',function(e){
  mx=e.clientX;my=e.clientY;
  var c=document.getElementById('cur');c.style.left=e.clientX+'px';c.style.top=e.clientY+'px';
});

// Start the RAF loop immediately (renders menu bg)
rafId=requestAnimationFrame(gameLoop);
})();
</script>
</body>
