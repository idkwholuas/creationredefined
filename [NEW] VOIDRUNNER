  document.getElementById('st-title').textContent=p.t;
  var bd=document.getElementById('st-body');bd.innerHTML='';
  var full=p.b,i=0;
  clearInterval(storyIv);
  storyIv=setInterval(function(){i=Math.min(i+3,full.length);bd.innerHTML=full.slice(0,i);if(i>=full.length)clearInterval(storyIv);},16);
  document.getElementById('st-next').textContent=storyPg<STORY.length-1?'CONTINUE ▶':'SELECT PILOT ▶';
}
document.getElementById('btn-story').onclick=function(){storyPg=0;showScr('sc-story');renderStory();};
document.getElementById('st-next').onclick=function(){storyPg++;if(storyPg>=STORY.length){buildChars();showScr('sc-chars');}else renderStory();};
document.getElementById('btn-chars').onclick=function(){buildChars();showScr('sc-chars');};
document.getElementById('btn-trophies').onclick=function(){buildTrophies();showScr('sc-trophy');};
document.getElementById('btn-back-trophy').onclick=function(){showScr('sc-menu');};
document.getElementById('btn-retry').onclick=function(){buildChars();showScr('sc-chars');};
document.getElementById('btn-menu').onclick=function(){showScr('sc-menu');};
document.getElementById('btn-launch').onclick=function(){startRun();};

