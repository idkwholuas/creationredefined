// ── RENDER ──────────────────────────────────────────────
function render(){
  cx.clearRect(0,0,W,H);
  cx.fillStyle='#030309';cx.fillRect(0,0,W,H);
  // Stars
  for(var i=0;i<stars.length;i++){var s=stars[i];cx.globalAlpha=s.a*(0.75+0.25*Math.sin(s.tw));cx.fillStyle='#fff';cx.beginPath();cx.arc(s.x,s.y,s.r,0,6.28);cx.fill();}
  cx.globalAlpha=1;
  // Nebula
  if(frame%5===0){cx.globalAlpha=0.02;cx.fillStyle='#5533aa';cx.beginPath();cx.arc(W*0.3,H*0.2,W*0.38,0,6.28);cx.fill();cx.globalAlpha=1;}
  // Shake
  var ox=0,oy=0;
  if(shake>0){ox=(Math.random()-0.5)*shake*0.7;oy=(Math.random()-0.5)*shake*0.7;cx.save();cx.translate(ox,oy);}
  // Pickups
  var pcols={hp:'#44ff88',sh:'#3366ff',wpn:'#ff8833',score:'#ffd060',slow:'#88ffff',inv:P.col};
  var picns={hp:'♥',sh:'◈',wpn:'◆',score:'★',slow:'❄',inv:'◉'};
  for(var i=0;i<pickups.length;i++){var p=pickups[i];cx.globalAlpha=0.88;cx.strokeStyle=pcols[p.type]||'#fff';cx.lineWidth=1.5;cx.beginPath();cx.arc(p.x,p.y,10+Math.sin(p.ang*2)*2.5,0,6.28);cx.stroke();cx.fillStyle=pcols[p.type]||'#fff';cx.font='11px Share Tech Mono';cx.textAlign='center';cx.textBaseline='middle';cx.fillText(picns[p.type]||'?',p.x,p.y);cx.globalAlpha=1;}
  // Particles
  for(var i=0;i<parts.length;i++){var p=parts[i];var al=p.life/(p.maxL||28);cx.globalAlpha=Math.min(al,0.9);if(p.ring){cx.strokeStyle=p.c;cx.lineWidth=2;cx.beginPath();cx.arc(p.x,p.y,p.sz*(1-al)*2.2,0,6.28);cx.stroke();}else{cx.fillStyle=p.c;cx.beginPath();cx.arc(p.x,p.y,p.sz,0,6.28);cx.fill();}}
  cx.globalAlpha=1;
  // Enemies
  for(var i=0;i<enemies.length;i++){var e=enemies[i];cx.save();cx.translate(e.x,e.y);cx.rotate(e.ang);cx.strokeStyle=e.c;cx.lineWidth=1.6;cx.globalAlpha=slowT>0?0.5:0.9;drawEnemy(e);if(e.maxHp>1){cx.globalAlpha=0.65;cx.fillStyle='#111';cx.fillRect(-e.sz,-e.sz-7,e.sz*2,3);cx.fillStyle=e.c;cx.fillRect(-e.sz,-e.sz-7,e.sz*2*(e.hp/e.maxHp),3);}if(e.marked){cx.strokeStyle='#f44';cx.lineWidth=1;cx.beginPath();cx.arc(0,0,e.sz+5,0,6.28);cx.stroke();}cx.restore();cx.globalAlpha=1;}
  // Boss
  if(boss){cx.save();cx.translate(boss.x,boss.y);cx.globalAlpha=0.18;cx.fillStyle=boss.c;cx.beginPath();cx.arc(0,0,boss.sz*2.3,0,6.28);cx.fill();for(var r=0;r<3;r++){cx.save();cx.rotate(boss.ang*(r%2?-1:1)+r*2.09);cx.strokeStyle=boss.c+(r?'55':'ff');cx.lineWidth=r?1:2;cx.beginPath();cx.arc(0,0,boss.sz*(1+r*0.3),0,6.28);cx.stroke();cx.restore();}cx.strokeStyle=boss.c;cx.lineWidth=2;cx.beginPath();for(var i=0;i<8;i++){var a=(i/8)*6.28+boss.ang;i?cx.lineTo(Math.cos(a)*boss.sz,Math.sin(a)*boss.sz):cx.moveTo(Math.cos(a)*boss.sz,Math.sin(a)*boss.sz);}cx.closePath();cx.stroke();cx.globalAlpha=0.2;cx.fillStyle=boss.c;cx.fill();cx.globalAlpha=1;cx.fillStyle='#fff';cx.beginPath();cx.arc(0,0,boss.sz*0.17,0,6.28);cx.fill();cx.fillStyle=boss.c;cx.beginPath();cx.arc(0,0,boss.sz*0.09,0,6.28);cx.fill();cx.restore();}
  // Bullets
  cx.globalAlpha=0.92;
  for(var i=0;i<bullets.length;i++){var b=bullets[i];cx.fillStyle=b.c;cx.beginPath();cx.arc(b.x,b.y,b.sz,0,6.28);cx.fill();}
  cx.globalAlpha=1;
  // Trail
  for(var i=1;i<P.trail.length;i++){cx.globalAlpha=(1-i/10)*0.45;cx.fillStyle=ghostT>0?'#22ffcc':P.inv>0&&(P.inv>>2)%2?'#ff4466':P.col;cx.beginPath();cx.arc(P.trail[i].x,P.trail[i].y,5*(1-i/10),0,6.28);cx.fill();}cx.globalAlpha=1;
  // Player
  var px=P.x,py=P.y,flicker=P.inv>0&&(P.inv>>2)%2===1&&!ghostT;
  if(!flicker){
    cx.globalAlpha=0.28;cx.fillStyle=ghostT>0?'#22ffcc':P.col;cx.beginPath();cx.ellipse(px,py+15,11,5,0,0,6.28);cx.fill();cx.globalAlpha=1;
    if(frame%3<2){cx.strokeStyle='rgba(255,255,255,.55)';cx.lineWidth=1.5;cx.beginPath();cx.moveTo(px-4,py+9);cx.lineTo(px,py+15+Math.random()*5);cx.lineTo(px+4,py+9);cx.stroke();}
    cx.fillStyle=ghostT>0?'#0a1a18':'#0b0b1d';cx.strokeStyle=ghostT>0?'#22ffcc':P.col;cx.lineWidth=1.8;
    cx.beginPath();cx.moveTo(px,py-16);cx.lineTo(px+11,py+10);cx.lineTo(px+5,py+6);cx.lineTo(px,py+9);cx.lineTo(px-5,py+6);cx.lineTo(px-11,py+10);cx.closePath();cx.fill();cx.stroke();
    cx.globalAlpha=0.5;cx.fillStyle=P.col;cx.beginPath();cx.ellipse(px,py-3,3,6,0,0,6.28);cx.fill();cx.globalAlpha=1;
    if(P.sh>0||shieldT>0){cx.globalAlpha=shieldT>0?0.4:0.1+Math.sin(frame*0.08)*0.07;cx.strokeStyle='#3366ff';cx.lineWidth=1.5;cx.beginPath();cx.arc(px,py,26,0,6.28);cx.stroke();cx.globalAlpha=1;}
    if(slowT>0){cx.globalAlpha=0.07+Math.sin(frame*0.14)*0.04;cx.strokeStyle='#88ffff';cx.lineWidth=2;cx.beginPath();cx.arc(px,py,200,0,6.28);cx.stroke();cx.globalAlpha=1;}
    if(radT>0){cx.globalAlpha=0.07+Math.sin(frame*0.18)*0.05;cx.fillStyle='#ffaa22';cx.beginPath();cx.arc(px,py,160,0,6.28);cx.fill();cx.globalAlpha=1;}
    if(lockOn>0&&frame%4<2){cx.strokeStyle='#ff4466';cx.lineWidth=1;cx.beginPath();cx.arc(px,py,22,0,6.28);cx.stroke();}
  }
  if(shake>0)cx.restore();
}

function drawEnemy(e){
  cx.beginPath();
  if(e.type==='drone'){cx.moveTo(0,-e.sz);cx.lineTo(e.sz*0.8,e.sz*0.7);cx.lineTo(0,e.sz*0.3);cx.lineTo(-e.sz*0.8,e.sz*0.7);cx.closePath();cx.stroke();cx.globalAlpha=0.12;cx.fillStyle=e.c;cx.fill();}
  else if(e.type==='bomber'){cx.lineWidth=4;cx.strokeStyle=e.c+'55';cx.moveTo(0,-e.sz);cx.lineTo(e.sz*0.9,e.sz*0.6);cx.lineTo(-e.sz*0.9,e.sz*0.6);cx.closePath();cx.stroke();cx.lineWidth=1.6;cx.strokeStyle=e.c;cx.stroke();}
  else if(e.type==='drifter'){for(var i=0;i<5;i++){var a=(i/5)*6.28-1.57,a2=((i+0.5)/5)*6.28-1.57;i?cx.lineTo(Math.cos(a)*e.sz,Math.sin(a)*e.sz):cx.moveTo(Math.cos(a)*e.sz,Math.sin(a)*e.sz);cx.lineTo(Math.cos(a2)*e.sz*0.4,Math.sin(a2)*e.sz*0.4);}cx.closePath();cx.stroke();cx.globalAlpha=0.14;cx.fillStyle=e.c;cx.fill();}
  else if(e.type==='splitter'){for(var i=0;i<4;i++){var a=(i/4)*6.28;i?cx.lineTo(Math.cos(a)*e.sz,Math.sin(a)*e.sz):cx.moveTo(Math.cos(a)*e.sz,Math.sin(a)*e.sz);}cx.closePath();cx.stroke();}
  else if(e.type==='seeker'){cx.arc(0,0,e.sz,0,6.28);cx.stroke();cx.moveTo(0,-e.sz*0.5);cx.lineTo(e.sz*0.4,e.sz*0.5);cx.lineTo(-e.sz*0.4,e.sz*0.5);cx.closePath();cx.stroke();}
  else if(e.type==='razor'){for(var i=0;i<6;i++){var a=(i/6)*6.28,r=i%2?e.sz*0.42:e.sz;i?cx.lineTo(Math.cos(a)*r,Math.sin(a)*r):cx.moveTo(Math.cos(a)*r,Math.sin(a)*r);}cx.closePath();cx.stroke();}
  else if(e.type==='swarm'){cx.arc(0,0,e.sz,0,6.28);cx.stroke();cx.moveTo(e.sz*0.4,0);cx.arc(0,0,e.sz*0.4,0,6.28);cx.stroke();}
  else if(e.type==='armored'){cx.lineWidth=3;for(var i=0;i<6;i++){var a=(i/6)*6.28;i?cx.lineTo(Math.cos(a)*e.sz,Math.sin(a)*e.sz):cx.moveTo(Math.cos(a)*e.sz,Math.sin(a)*e.sz);}cx.closePath();cx.stroke();}
  else if(e.type==='elite'){for(var i=0;i<7;i++){var a=(i/7)*6.28;i?cx.lineTo(Math.cos(a)*e.sz,Math.sin(a)*e.sz):cx.moveTo(Math.cos(a)*e.sz,Math.sin(a)*e.sz);}cx.closePath();cx.stroke();cx.globalAlpha=0.2;cx.fillStyle=e.c;cx.fill();}
}

